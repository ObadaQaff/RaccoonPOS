<Window x:Class="RaccoonWarehouse.UsersTable"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        mc:Ignorable="d"
        Title="إدارة المستخدمين"
        Height="800"
        Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        FlowDirection="RightToLeft"
        Background="{StaticResource AppPageBackgroundBrush}">
    <Grid Background="{StaticResource AppPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="220"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="0,0,34,34" Background="{StaticResource AppDashboardHeroBrush}">
            <Grid Margin="34,24,34,34">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="إدارة المستخدمين"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="18,12"
                        CornerRadius="20"
                        Background="#1FFFFFFF"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="صلاحية الإنشاء"
                                   FontSize="12"
                                   Foreground="#CFE8E3"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="CreatePermissionText"
                                   Margin="0,4,0,0"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24,-52,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource AppCardBorderStyle}"
                    Padding="24">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="340"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="SearchBox"
                                 Grid.Column="0"
                                 Style="{StaticResource AppSearchTextBoxStyle}"
                                 TextChanged="SearchBox_TextChanged"
                                 ToolTip="ابحث بالاسم أو الهاتف أو الدور"/>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <Border Style="{StaticResource AppBadgeBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="إجمالي المستخدمين"
                                               FontSize="12"
                                               Foreground="{StaticResource AppMutedTextBrush}"/>
                                    <TextBlock x:Name="TotalUsersText"
                                               Margin="0,4,0,0"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource AppTextBrush}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource AppBadgeBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="النتائج المعروضة"
                                               FontSize="12"
                                               Foreground="{StaticResource AppMutedTextBrush}"/>
                                    <TextBlock x:Name="VisibleUsersText"
                                               Margin="0,4,0,0"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource AppTextBrush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Left">
                            <Button x:Name="CreateUserBtn"
                                    Width="170"
                                    Style="{StaticResource AppHeroButtonStyle}"
                                    Click="CreateUserBtn_Click">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <fa:ImageAwesome Icon="Plus" Width="16" Height="16"
                                                     Margin="0,0,8,0"
                                                     Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <TextBlock Text="مستخدم جديد" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BackBtn"
                                    Width="120"
                                    Style="{StaticResource AppSecondaryButtonStyle}"
                                    Click="BackBtn_Click">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <fa:ImageAwesome Icon="ArrowRight" Width="16" Height="16"
                                                     Margin="0,0,8,0"
                                                     Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <TextBlock Text="عودة" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <TextBlock x:Name="AdminHintText"
                               Margin="2,16,0,0"
                               FontSize="13"
                               Foreground="{StaticResource AppMutedTextBrush}"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,18,0,0"
                    Style="{StaticResource AppCardBorderStyle}"
                    Padding="16">
                <DataGrid x:Name="UsersTable1"
                          Style="{StaticResource AppModernDataGridStyle}"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          MouseDoubleClick="UsersTable1_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="المعرف" Binding="{Binding Id}" Width="90"/>
                        <DataGridTextColumn Header="الاسم" Binding="{Binding Name}" Width="2*"/>
                        <DataGridTextColumn Header="الهاتف" Binding="{Binding PhoneNumber}" Width="1.6*"/>
                        <DataGridTextColumn Header="الدور" Binding="{Binding Role}" Width="1.1*"/>
                        <DataGridTextColumn Header="آخر تحديث" Binding="{Binding UpdatedDate, StringFormat={}{0:yyyy-MM-dd hh:mm tt}}" Width="1.5*"/>
                    </DataGrid.Columns>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Style="{StaticResource AppMenuItemStyle}" Header="تعديل" Click="Update_User"/>
                            <MenuItem Style="{StaticResource AppMenuItemStyle}" Header="حذف" Click="Delete_User"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Window>
