<Window x:Class="RaccoonWarehouse.UpdateUser"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RaccoonWarehouse"
        mc:Ignorable="d"
        Loaded="Window_Loaded"
        Title="تحديث بيانات المستخدم" Height="800" Width="1400" WindowState="Maximized">
    <Grid FlowDirection="RightToLeft"  Background="#FFF7F7F7" HorizontalAlignment="Stretch" RenderTransformOrigin="0.552,0.576"  Margin="0,0,0,-16" Width="1400">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0*"/>
            <ColumnDefinition Width="464*"/>
            <ColumnDefinition Width="180*"/>
            <ColumnDefinition Width="108*"/>
            <ColumnDefinition Width="71*"/>
            <ColumnDefinition Width="350*"/>
            <ColumnDefinition Width="241*"/>
        </Grid.ColumnDefinitions>
        <TextBox x:Name="FullName" Grid.ColumnSpan="4" HorizontalAlignment="Left" Margin="267,223,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="396" Height="35" FontSize="22" Background="#FFF2E7D5" RenderTransformOrigin="0.536,0.426"/>
        <Label Content="تحديث بيانات المستخدم" HorizontalAlignment="Left" Margin="67,39,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.942,-1.156" Height="85" Width="390" FontSize="48" Grid.Column="2" FontFamily="Akhbar MT" Background="{x:Null}" HorizontalContentAlignment="Center" FontWeight="Bold" Foreground="#FF393E46" Grid.ColumnSpan="4"/>
        <Label Content="الإسم" HorizontalAlignment="Left" Margin="267,192,0,0" VerticalAlignment="Top" Width="87" FontSize="16" Grid.Column="1" Height="31"/>
        <TextBox x:Name="PhoneNumber" HorizontalAlignment="Left" Margin="62,226,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="396" Height="35" FontSize="22" Background="#FFF2E7D5" Grid.Column="4" Grid.ColumnSpan="3"/>
        <Label Content="رقم الهاتف" HorizontalAlignment="Left" Margin="56,188,0,0" VerticalAlignment="Top" Width="128" FontSize="16" Grid.Column="4" Height="31" Grid.ColumnSpan="2"/>
        <TextBox x:Name="Password" HorizontalAlignment="Left" Margin="267,339,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="396" Height="35" FontSize="22" Background="#FFF2E7D5" Grid.Column="1" Grid.ColumnSpan="3"/>
        <Label Content="كلمة المرور" HorizontalAlignment="Left" Margin="267,301,0,0" VerticalAlignment="Top" Width="87" FontSize="16" Grid.Column="1" Height="31"/>
        <TextBox HorizontalAlignment="Left" Margin="62,351,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="396" Height="35" FontSize="22" Background="#FFF2E7D5" Grid.Column="4" Grid.ColumnSpan="3"/>
        <Label Content="تاكيد كلمة المرور " HorizontalAlignment="Left" Margin="56,313,0,0" VerticalAlignment="Top" Width="154" FontSize="16" Grid.Column="4" Height="31" Grid.ColumnSpan="2"/>
        <Label Content="نوع الحساب" HorizontalAlignment="Left" Margin="276,416,0,0" VerticalAlignment="Top" Width="87" FontSize="16" Grid.Column="1" Height="31"/>
        <Button Grid.Column="4" Content="تحديث" HorizontalAlignment="Left" Margin="3,570,0,0" VerticalAlignment="Top" Height="62" Width="180" FontSize="20" Background="#FF6D9886" Foreground="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" FontWeight="Bold" Click="Update_User" Grid.ColumnSpan="2"/>
        <ComboBox x:Name="Role" Grid.Column="1" HorizontalAlignment="Left" Margin="286,452,0,0" VerticalAlignment="Top" Width="154" Height="41" FontSize="18"/>
        <Button x:Name="BackBtn" Grid.Column="2" Content="عودة" HorizontalAlignment="Left" Height="62" Margin="74,570,0,0" VerticalAlignment="Top" Width="170" FontSize="18" FontWeight="Bold" Background="#FFD5E3CF" Click="BackBtn_Click" Grid.ColumnSpan="2"/>

    </Grid>
</Window>
