<Window x:Class="RaccoonWarehouse.UpdateUser"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Loaded="Window_Loaded"
        Title="تحديث بيانات المستخدم"
        Height="820"
        Width="1280"
        WindowState="Maximized"
        FlowDirection="RightToLeft"
        Background="{StaticResource AppPageBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="240"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="0,0,36,36" Background="{StaticResource AppBlueHeroBrush}">
            <Grid Margin="34,24,34,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="تحديث بيانات المستخدم"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="20,14"
                        Background="#1AFFFFFF"
                        CornerRadius="20"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="هوية السجل"
                                   FontSize="12"
                                   Foreground="#D7E5ED"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="UserIdText"
                                   Margin="0,4,0,0"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="28,-70,28,28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource AppCardBorderStyle}"
                    Padding="28"
                    Margin="0,0,20,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,18,18">
                        <TextBlock Text="اسم المستخدم" Style="{StaticResource AppFieldLabelStyle}"/>
                        <TextBox x:Name="FullName" Style="{StaticResource AppTextInputStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="18,0,0,18">
                        <TextBlock Text="رقم الهاتف" Style="{StaticResource AppFieldLabelStyle}"/>
                        <TextBox x:Name="PhoneNumber" Style="{StaticResource AppTextInputStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,18,18">
                        <TextBlock Text="كلمة المرور" Style="{StaticResource AppFieldLabelStyle}"/>
                        <TextBox x:Name="Password" Style="{StaticResource AppTextInputStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="18,0,0,18">
                        <TextBlock Text="تأكيد كلمة المرور" Style="{StaticResource AppFieldLabelStyle}"/>
                        <TextBox x:Name="ConfirmPassword" Style="{StaticResource AppTextInputStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,18,18">
                        <TextBlock Text="نوع الحساب" Style="{StaticResource AppFieldLabelStyle}"/>
                        <ComboBox x:Name="Role" Style="{StaticResource AppComboBoxStyle}"/>
                    </StackPanel>

                    <TextBlock x:Name="FormHintText"
                               Grid.Row="3"
                               Grid.ColumnSpan="2"
                               FontSize="13"
                               Foreground="{StaticResource AppMutedTextBrush}"
                               Text="راجع الاسم والدور وكلمة المرور قبل الحفظ. يتم تحديث المستخدم مباشرة بعد الاعتماد."/>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource AppCardBorderStyle}"
                    Padding="24">
                <StackPanel>
                    <TextBlock Text="ملخص سريع"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource AppBlueBrush}"/>
                    <TextBlock Margin="0,12,0,0"
                               FontSize="14"
                               Foreground="{StaticResource AppMutedTextBrush}"
                               Text="استخدم هذه الشاشة لتعديل معلومات الحساب دون التنقل بين نوافذ متعددة."/>

                    <Border Margin="0,24,0,0"
                            Padding="18"
                            Background="{StaticResource AppPanelSoftBrush}"
                            CornerRadius="20">
                        <StackPanel>
                            <TextBlock Text="آخر خطوة"
                                       FontSize="12"
                                       Foreground="{StaticResource AppMutedTextBrush}"/>
                            <TextBlock Text="التأكد من تطابق كلمة المرور"
                                       Margin="0,6,0,0"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AppTextBrush}"/>
                        </StackPanel>
                    </Border>

                    <Button Margin="0,34,0,0"
                            Content="حفظ التحديث"
                            Style="{StaticResource AppFormButtonStyle}"
                            Background="{StaticResource AppBlueBrush}"
                            Click="Update_User"/>
                    <Button x:Name="BackBtn"
                            Margin="0,14,0,0"
                            Content="عودة"
                            Style="{StaticResource AppSecondaryButtonStyle}"
                            Background="{StaticResource AppAccentBrush}"
                            Foreground="{StaticResource AppTextBrush}"
                            Click="BackBtn_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
