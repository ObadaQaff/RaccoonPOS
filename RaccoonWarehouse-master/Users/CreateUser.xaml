<Window x:Class="RaccoonWarehouse.CreateUser"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="إنشاء مستخدم" Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <!-- TextBox Style -->
        <Style TargetType="TextBox" x:Key="InputBoxStyle">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#FFF2E7D5"/>
            <Setter Property="BorderBrush" Value="#EBCB90"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>

        <!-- ComboBox Style -->
        <Style TargetType="ComboBox" x:Key="InputComboStyle">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#FFF2E7D5"/>
            <Setter Property="BorderBrush" Value="#EBCB90"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>

        <!-- Button Style -->
        <Style TargetType="Button" x:Key="PrimaryButtonStyle">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="Background" Value="#3396D3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8"
                                Padding="10,5">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBCB90"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="#EEEEEE">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Main Content -->
            <RowDefinition Height="60"/>
            <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#3396D3" Grid.Row="0">
            <TextBlock Text="إنشاء مستخدم"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- MAIN FORM -->
        <Border Grid.Row="1"
                Background="#FFF0CE"
                Margin="20"
                CornerRadius="10"
                Padding="40">
            <StackPanel FlowDirection="RightToLeft">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Column -->
                    <StackPanel Grid.Column="0" Margin="20,0,40,0">
                        <Label Content="الإسم" FontWeight="Bold" FontSize="16"/>
                        <TextBox x:Name="FullName" Style="{StaticResource InputBoxStyle}"/>

                        <Label Content="كلمة المرور" FontWeight="Bold" FontSize="16"/>
                        <TextBox x:Name="Password" Style="{StaticResource InputBoxStyle}"/>
                    </StackPanel>

                    <!-- Right Column -->
                    <StackPanel Grid.Column="1" Margin="40,0,20,0">

                        <Label Content="رقم الهاتف" FontWeight="Bold" FontSize="16"/>
                        <TextBox x:Name="PhoneNumber" Style="{StaticResource InputBoxStyle}"/>

                        <Label Content="تأكيد كلمة المرور" FontWeight="Bold" FontSize="16"/>
                        <TextBox x:Name="ConfirmPassword" Style="{StaticResource InputBoxStyle}"/>
                    </StackPanel>
                </Grid>

                <!-- Role & Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
                    <StackPanel Width="200">
                        <Label Content="نوع الحساب" FontWeight="Bold" FontSize="16"/>
                        <ComboBox x:Name="Role" Style="{StaticResource InputComboStyle}">
                            
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="40,30,0,0" VerticalAlignment="Bottom">
                        <Button x:Name="CreateBtn" Content="إنشاء" Style="{StaticResource PrimaryButtonStyle}" Width="150"
                                Click="Button_Click"/>
                        <Button x:Name="BackBtn" Content="عودة" Style="{StaticResource PrimaryButtonStyle}" Width="150"
                                Background="#EBCB90" Foreground="Black"
                                Click="BackBtn_Click" Margin="20,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- FOOTER -->
        <Border Background="#FFF0CE" Grid.Row="2">
            <TextBlock Text="© 2025 Raccoon Warehouse"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="#3396D3"
                       FontSize="14"
                       FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>
