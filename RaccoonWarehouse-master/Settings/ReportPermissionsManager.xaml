<Window x:Class="RaccoonWarehouse.Settings.ReportPermissionsManager"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="مدير صلاحيات التقارير"
        Height="780"
        Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#F2F6FA"
        FlowDirection="RightToLeft">

    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2D8DCF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#E3EAF0"/>
            <Setter Property="Foreground" Value="#2D8DCF"/>
        </Style>

        <Style x:Key="InputBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CBD5DF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="MinimalDataGrid" TargetType="DataGrid">
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="ColumnHeaderHeight" Value="46"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="BorderBrush" Value="#D0D7DD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="AlternatingRowBackground" Value="#F7FAFD"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Border Background="#2D8DCF" Grid.Row="0">
            <TextBlock Text="مدير صلاحيات التقارير"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
        </Border>

        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="White"
                    CornerRadius="12"
                    BorderBrush="#D0D7DD"
                    BorderThickness="1"
                    Padding="14"
                    Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="380"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="8,0">
                        <TextBlock Text="بحث باسم التقرير" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,6"/>
                        <TextBox x:Name="SearchTextBox"
                                 Style="{StaticResource InputBoxStyle}"
                                 TextChanged="SearchTextBox_TextChanged"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Text="اختر من يمكنه مشاهدة كل تقرير. عدم وجود سجل يعني السماح افتراضيًا."
                               VerticalAlignment="Bottom"
                               Margin="10,0"
                               Foreground="#55616E"
                               FontSize="14"/>

                    <Button Grid.Column="2"
                            Width="120"
                            Margin="10,24,10,0"
                            VerticalAlignment="Top"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="SaveBtn_Click"
                            Content="حفظ"/>

                    <Button Grid.Column="3"
                            Width="120"
                            Margin="10,24,0,0"
                            VerticalAlignment="Top"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="CloseBtn_Click"
                            Content="إغلاق"/>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="White"
                    CornerRadius="12"
                    BorderBrush="#D0D7DD"
                    BorderThickness="1"
                    Padding="10">
                <DataGrid x:Name="PermissionsGrid"
                          AutoGenerateColumns="False"
                          Style="{StaticResource MinimalDataGrid}"/>
            </Border>
        </Grid>

        <Border Background="#E3EAF0" Grid.Row="2">
            <TextBlock Text="© 2026 Raccoon Warehouse"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="#2D8DCF"
                       FontWeight="SemiBold"
                       FontSize="14"/>
        </Border>
    </Grid>
</Window>
