<Window x:Class="RaccoonWarehouse.Stocks.StockIn"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        mc:Ignorable="d"
        Title="سند إدخال بضاعة"

        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <!-- ============== RESOURCES (same palette & styles as PaymentVoucher) ============== -->
    <Window.Resources>

        <!-- Primary button (blue) -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2D8DCF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                         CornerRadius="8"
                         Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2479B6"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1E6A9E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary button (light gray-blue) -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button"
        BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#E3EAF0"/>
            <Setter Property="Foreground" Value="#2D8DCF"/>
        </Style>

        <!-- TextBox modern style -->
        <Style x:Key="InputBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CBD5DF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                         BorderBrush="{TemplateBinding BorderBrush}"
                         BorderThickness="{TemplateBinding BorderThickness}"
                         CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#2D8DCF"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="6" Color="#A8D2FF" ShadowDepth="0"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern ComboBox -->
        <Style x:Key="ComboBoxStyleModern" TargetType="ComboBox">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="IsEditable" Value="True"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CBD5DF"/>
            <Setter Property="BorderThickness" Value="1"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">

                        <Grid>

                            <!-- Border -->
                            <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"/>

                            <!-- Editable Textbox -->
                            <TextBox x:Name="PART_EditableTextBox"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="8,0,30,0"
                             VerticalContentAlignment="Center"
                             HorizontalContentAlignment="Right"
                             Visibility="Visible"/>

                            <!-- ToggleButton (Drop arrow) -->
                            <ToggleButton x:Name="DropDownToggle"
                                  Grid.Column="1"
                                  Focusable="False"
                                  Background="Transparent"
                                  BorderBrush="Transparent"
                                  BorderThickness="0"
                                  Width="28"
                                  HorizontalAlignment="Left"
                                  Content="▼"
                                  FontSize="12"
                                  Foreground="#777"
                                  IsChecked="{Binding IsDropDownOpen,
                                      Mode=TwoWay,
                                      RelativeSource={RelativeSource TemplatedParent}}"/>

                            <!-- Popup -->
                            <Popup x:Name="PART_Popup"
                           Placement="Bottom"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           AllowsTransparency="True"
                           Focusable="False"
                           PopupAnimation="Slide">

                                <Border Background="White"
                                BorderBrush="#D0D0D0"
                                BorderThickness="1"
                                CornerRadius="6"
                                Margin="0,2,0,0">

                                    <ScrollViewer Margin="2"
                                          SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                            KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>

                                </Border>
                            </Popup>

                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#2D8DCF"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#2D8DCF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>

        </Style>


        <!-- Modern DataGrid -->
        <Style x:Key="MinimalDataGrid" TargetType="DataGrid">
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="ColumnHeaderHeight" Value="44"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="BorderBrush" Value="#CBD5DF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F2F6FA"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E0E6EB"/>
        </Style>

        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

    </Window.Resources>


    <!-- ============== LAYOUT ============== -->
    <Grid Background="#EEEEEE">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#3396D3" Grid.Row="0">
            <TextBlock Text="سند إدخال بضاعة"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel VerticalAlignment="Top"
                        HorizontalAlignment="Center"
                        Width="850"
                        Margin="0,20,0,20"
                        FlowDirection="RightToLeft">

                <!-- TOP FIELDS (minimal, 2 columns like PaymentVoucher) -->
                <!-- TOP FIELDS (compact grid) -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="210"/>
                        <!-- رقم السند -->
                        <ColumnDefinition Width="200"/>
                        <!-- التاريخ -->
                        <ColumnDefinition Width="250"/>
                        <!-- اسم المورد -->
                    </Grid.ColumnDefinitions>

                    <!-- رقم السند -->
                    <StackPanel Margin="6" Grid.Column="0">
                        <TextBlock Text="رقم السند" Style="{StaticResource HeaderText}" FontSize="14"/>
                        <TextBox x:Name="VoucherNumberTxt" Style="{StaticResource InputBoxStyle}" Width="200"/>
                    </StackPanel>

                    <!-- التاريخ -->
                    <StackPanel Margin="6" Grid.Column="1">
                        <TextBlock Text="التاريخ" Style="{StaticResource HeaderText}" FontSize="14"/>
                        <DatePicker x:Name="DatePickerInvoice" Height="32" FontSize="13" Width="180"/>
                    </StackPanel>

                    <!-- اسم المورد -->
                    <StackPanel Margin="6" Grid.Column="2"/>
                </Grid>

                <!-- ====== PRODUCT INPUT SECTION ====== -->
                <StackPanel Margin="10" Orientation="Vertical" Background="#E8F0F7" >

                    <TextBlock Text="إضافة منتج" Style="{StaticResource HeaderText}"/>

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="250"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- 🔹 Product -->
                        <StackPanel Grid.Column="0" Margin="0">
                            <TextBlock Text="المنتج"/>

                            <Grid Width="220">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="17"/>
                                    
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="المنتج"/>
                                <ComboBox x:Name="ProductBox"
                                        Style="{StaticResource ComboBoxStyleModern}"
                                        ItemsSource="{Binding Products}"
                                        DisplayMemberPath="Name"
                                        SelectedValuePath="Id"
                                        SelectionChanged="ProductBox_SelectionChanged"
                                        TextSearch.TextPath="Name"
                                        IsEditable="True" />

                                <!-- Search Button -->
                                <Button Width="25"
                                    Height="25"
                                    BorderThickness="0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="White"
                                    Cursor="Hand"
                                    Click="SearchProductBtn_Click">
                                    <fa:ImageAwesome Icon="Search"
                                    Width="16" Height="14"
                                    Foreground="Black"/>
                                </Button>
                                <!-- Clear Button -->
                                <Button Grid.Column="2"
                                    Width="20"
                                    Height="20"
                                    Foreground="Black"
                                    BorderBrush="Transparent"
                                    FontWeight="Bold"
                                    Cursor="Hand"
                                    ToolTip="مسح"
                                    Click="ClearProductBtn_Click">
                                    ✖
                                </Button>
                            </Grid>
                        </StackPanel>



                        <!-- 🔹 Unit -->
                        <StackPanel Grid.Column="1" Margin="6">
                            <TextBlock Text="الوحدة"/>
                            <ComboBox x:Name="UnitBox"
                      Style="{StaticResource ComboBoxStyleModern}"
                      DisplayMemberPath="Unit.Name"
                      SelectedValuePath="Id" Height="39"/>
                        </StackPanel>

                        <!-- 🔹 Qty -->
                        <StackPanel Grid.Column="2" Margin="6">
                            <TextBlock Text="الكمية"/>
                            <TextBox x:Name="QtyBox"
                     Style="{StaticResource InputBoxStyle}"
                     HorizontalContentAlignment="Center"/>
                        </StackPanel>

                        <!-- 🔹 Purchase Price -->
                        <StackPanel Grid.Column="3" Margin="6">
                            <TextBlock Text="سعر الشراء"/>
                            <TextBox x:Name="PurchaseBox"
                     Style="{StaticResource InputBoxStyle}"
                     HorizontalContentAlignment="Center"/>
                        </StackPanel>

                        <!-- 🔹 Sale Price -->
                        <StackPanel Grid.Column="4" Margin="6">
                            <TextBlock Text="سعر البيع"/>
                            <TextBox x:Name="SaleBox"
                     Style="{StaticResource InputBoxStyle}"
                     HorizontalContentAlignment="Center"/>
                        </StackPanel>

                        <!-- 🔹 Expiry Date -->
                        <StackPanel Grid.Column="5" Margin="6">
                            <TextBlock Text="تاريخ الانتهاء"/>
                            <DatePicker x:Name="ExpiryBox" Height="32" FontSize="15" Width="122"/>
                        </StackPanel>

                        <!-- 🔹 Add Button -->
                        <StackPanel Grid.Column="6" VerticalAlignment="Bottom" Margin="6">
                            <Button Content="إضافة"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="70"
                            Click="AddProduct_Click"/>
                        </StackPanel>

                    </Grid>
                </StackPanel>

                <!-- المنتجات -->
                <StackPanel Margin="10,0,10,10">
                    <TextBlock Text="المنتجات" Style="{StaticResource HeaderText}"/>
                    <DataGrid x:Name="ProductsGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          Style="{StaticResource MinimalDataGrid}"
                          Margin="0,0,0,10">    

                        <DataGrid.Columns>

                            <!-- Product Name -->
                            <DataGridTextColumn Header="المنتج" Width="180"
                            Binding="{Binding ProductName}" />

                            <!-- Unit -->
                            <DataGridTextColumn Header="الوحدة" Width="100"
                            Binding="{Binding UnitName}" />

                            <!-- Qty -->
                            <DataGridTextColumn Header="الكمية" Width="70"
                            Binding="{Binding Quantity}" />

                            <!-- Purchase Price -->
                            <DataGridTextColumn Header="سعر الشراء" Width="100"
                            Binding="{Binding PurchasePrice}" />

                            <!-- Sale Price -->
                            <DataGridTextColumn Header="سعر البيع" Width="100"
                            Binding="{Binding SalePrice}" />

                            <!-- Expiry -->
                            <DataGridTextColumn Header="تاريخ الانتهاء" Width="150"
                            Binding="{Binding ExpiryDate, StringFormat=yyyy-MM-dd}" />

                            <!-- Delete Button -->
                            <DataGridTemplateColumn Header="حذف" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="🗑"
                                            Background="Transparent"
                                            Foreground="Red"
                                            FontSize="16"
                                            Cursor="Hand"
                                            BorderThickness="0"
                                            Click="DeleteProduct_Click" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>

                    </DataGrid>


                    
                    
                </StackPanel>

                <!-- ملاحظات -->
                <StackPanel Margin="10,10,10,0">
                    <TextBlock Text="ملاحظات" Style="{StaticResource HeaderText}"/>
                    <TextBox x:Name="NotesTxt" Style="{StaticResource InputBoxStyle}"
                         Height="70" Width="800"
                         TextWrapping="Wrap" AcceptsReturn="True"/>             

                </StackPanel>

                <!-- ACTION BUTTONS -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,24,0,0">
                    <Button x:Name="BackBtn"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="150"
                         FontSize="14"
                         Padding="8,4"
                            Click="BackBtn_Click"
                            Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <fa:ImageAwesome Icon="ArrowLeft" Width="18" Height="18"
                                             Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="رجوع" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="SaveStockInBtn"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="150"
                            FontSize="14"
                            Padding="8,4"
                            Margin="0,0,15,0"
                            Click="SaveStockInBtn_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <fa:ImageAwesome Icon="Save" Width="18" Height="18"
                                             Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="حفظ" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="SearchStockBtn"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="180"
                            Click="SearchStockBtn_Click"    
                            Margin="0,0,15,0">  
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <fa:ImageAwesome Icon="Search" Width="18" Height="18"
                                 Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="استعلام" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="PrintBtn"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="180"
                        Margin="0,0,15,0"
                        Visibility="Collapsed" 
                        Click="PrintBtn_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <fa:ImageAwesome Icon="Print" Width="18" Height="18"
                         Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"/>
                            <TextBlock Text="طباعة" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="NewStockInBtn"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="180"
                        Click="NewStockInBtn_Click"
                        Margin="0,0,15,0"
                        Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <fa:ImageAwesome Icon="Plus" Width="18" Height="18"
                         Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="سند جديد" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                


                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- FOOTER -->
        <Border Background="#E8F0F7" Grid.Row="2">
            <TextBlock Text="© 2025 Raccoon Warehouse"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="#3396D3"
                       FontSize="14"
                       FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>
