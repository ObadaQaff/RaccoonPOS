<Window x:Class="RaccoonWarehouse.Stocks.Reports.StockMovementsReport"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        Title="حركة الأصناف"
        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F2F6FA"
        FlowDirection="RightToLeft">

    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2D8DCF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#E3EAF0"/>
            <Setter Property="Foreground" Value="#2D8DCF"/>
        </Style>

        <Style x:Key="MinimalDataGrid" TargetType="DataGrid">
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="ColumnHeaderHeight" Value="44"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="BorderBrush" Value="#D0D7DD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="AlternatingRowBackground" Value="#F7FAFD"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#2D8DCF" CornerRadius="12" Padding="12" Grid.Row="0">
            <TextBlock Text="حركة الأصناف"
                       Foreground="White"
                       FontSize="26"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- FILTER BAR -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                BorderBrush="#D0D7DD"
                BorderThickness="1"
                Padding="14"
                Margin="0,12,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="8,0">
                    <TextBlock Text="من تاريخ" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <DatePicker x:Name="FromDatePicker" Height="38" FontSize="15"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="8,0">
                    <TextBlock Text="إلى تاريخ" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <DatePicker x:Name="ToDatePicker" Height="38" FontSize="15"/>
                </StackPanel>

                <TextBlock Grid.Column="2"
                           VerticalAlignment="Bottom"
                           Foreground="#666"
                           Margin="8,0,0,4"
                           Text="يعرض جميع حركات الدخول/الخروج حسب المستندات (شراء/بيع/تسوية...)"/>

                <Button Grid.Column="3"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="160"
                        Margin="10,0,0,0"
                        Click="GenerateReportBtn_Click">
                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="File" Width="16" Height="16"/>
                        <TextBlock Text=" عرض التقرير" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="4"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="120"
                        Margin="10,0,0,0"
                        Click="BackBtn_Click">
                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="ArrowLeft" Width="16" Height="16"/>
                        <TextBlock Text=" رجوع" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- GRID -->
        <DataGrid x:Name="MovementsGrid"
                  Grid.Row="2"
                  Style="{StaticResource MinimalDataGrid}"
                  AutoGenerateColumns="False">

            <DataGrid.Columns>
                <DataGridTextColumn Header="التاريخ" Binding="{Binding Date, StringFormat=yyyy-MM-dd HH:mm}" Width="180"/>
                <DataGridTextColumn Header="رقم المستند" Binding="{Binding DocumentNumber}" Width="180"/>
                <DataGridTextColumn Header="نوع المستند" Binding="{Binding DocumentType}" Width="160"/>
                <DataGridTextColumn Header="كود الصنف" Binding="{Binding ProductId}" Width="120"/>
                <DataGridTextColumn Header="اسم الصنف" Binding="{Binding ProductName}" Width="260"/>
                <DataGridTextColumn Header="الوحدة" Binding="{Binding UnitName}" Width="140"/>
                <DataGridTextColumn Header="الكمية" Binding="{Binding Quantity}" Width="120"/>
                <DataGridTextColumn Header="سعر الشراء" Binding="{Binding PurchasePrice}" Width="140"/>
                <DataGridTextColumn Header="سعر البيع" Binding="{Binding SalePrice}" Width="140"/>
                <DataGridTextColumn Header="تم بواسطة" Binding="{Binding CreatedBy}" Width="200"/>
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</Window>