<Window x:Class="RaccoonWarehouse.Stocks.Reports.LowStockReport"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        Title="تقرير بضائع تحت الحد الأدنى"
        Height="750" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#EEF3F7"
        FlowDirection="RightToLeft">

    <Window.Resources>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#EEF3F7"/>
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#F8FBFD"/>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D6DEE6"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#C84D4D"/>
        <SolidColorBrush x:Key="SoftDangerBrush" Color="#FCE7E7"/>

        <LinearGradientBrush x:Key="HeroBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#356FA8" Offset="0"/>
            <GradientStop Color="#0F5B52" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="ReportDataGridStyle" TargetType="DataGrid">
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="ColumnHeaderHeight" Value="46"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E9EEF3"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="BorderBrush" Value="#D6DEE6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FBFD"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F1F6FA"/>
                        <Setter Property="Foreground" Value="#27445D"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="BorderBrush" Value="#DDE5EC"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="TextBlock.TextAlignment" Value="Center"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="22,20,22,14"
                CornerRadius="28"
                Padding="24"
                Background="{StaticResource HeroBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#204B72"
                        CornerRadius="20"
                        Padding="16,12">
                    <StackPanel>
                        <TextBlock Text="عدد الأصناف الحرجة"
                                   Foreground="#D5E7F4"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="CountText"
                                   Foreground="White"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="18,0,0,0"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <TextBlock Text="بضائع تحت الحد الأدنى"
                               Foreground="White"
                               FontSize="31"
                               FontWeight="Bold"
                               HorizontalAlignment="Right"/>
                    <TextBlock Text="قائمة الأصناف التي تحتاج إلى تعزيز سريع قبل التأثير على البيع أو التوريد."
                               Foreground="#D3E6F3"
                               FontSize="15"
                               Margin="0,6,0,0"
                               HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="22,0,22,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="22"
                    Padding="18"
                    Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="74"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="54"
                            Height="54"
                            CornerRadius="18"
                            Background="{StaticResource SoftDangerBrush}">
                        <fa:ImageAwesome Icon="Warning"
                                         Foreground="{StaticResource DangerBrush}"
                                         Width="24"
                                         Height="24"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="مراقبة المخزون الحرج"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#27445D"/>
                        <TextBlock Text="يعرض هذا التقرير كل صنف أصبح أقل من حدّه الأدنى اعتماداً على الرصيد الحالي."
                                   FontSize="14"
                                   Foreground="#687C8F"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="White"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="24"
                    Padding="14">
                <DataGrid x:Name="LowStockGrid"
                          AutoGenerateColumns="False"
                          Style="{StaticResource ReportDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="كود الصنف" Binding="{Binding ITEMCODE}" Width="150"/>
                        <DataGridTextColumn Header="اسم الصنف" Binding="{Binding ProductName}" Width="300"/>
                        <DataGridTextColumn Header="الوحدة" Binding="{Binding UnitName}" Width="130"/>
                        <DataGridTextColumn Header="الكمية الحالية" Binding="{Binding CurrentQuantity}" Width="150"/>
                        <DataGridTextColumn Header="الحد الأدنى" Binding="{Binding MinimumQuantity}" Width="150"/>
                        <DataGridTextColumn Header="النقص" Binding="{Binding Shortage}" Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Margin="22,0,22,20"
                Background="#E8EEF3"
                CornerRadius="18"
                Padding="12">
            <TextBlock Text="© 2026 Raccoon Warehouse"
                       HorizontalAlignment="Center"
                       Foreground="#416784"
                       FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>
