<Window x:Class="RaccoonWarehouse.Stocks.Reports.StockBalanceByDateReport"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        Title="أرصدة المخزون بتاريخ"
        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F2F6FA"
        FlowDirection="RightToLeft">

    <Window.Resources>

        <!-- Primary button -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2D8DCF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary button -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#E3EAF0"/>
            <Setter Property="Foreground" Value="#2D8DCF"/>
        </Style>

        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CBD5DF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Modern DataGrid -->
        <Style x:Key="MinimalDataGrid" TargetType="DataGrid">
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="ColumnHeaderHeight" Value="44"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="BorderBrush" Value="#D0D7DD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="AlternatingRowBackground" Value="#F7FAFD"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="Auto"/>
            <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#2D8DCF" Grid.Row="0" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="1"
                           Text="أرصدة المخزون بتاريخ"
                           Foreground="White"
                           FontSize="28"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>

                <!-- Optional icon -->
                <fa:ImageAwesome Grid.Column="2"
                                 Icon="Cubes"
                                 Width="22" Height="22"
                                 Foreground="White"
                                 VerticalAlignment="Center"
                                 Margin="10,0,0,0"/>
            </Grid>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Filters -->
                <RowDefinition Height="*"/>
                <!-- Grid -->
            </Grid.RowDefinitions>

            <!-- FILTER BAR -->
            <Border Background="White"
                    CornerRadius="12"
                    BorderBrush="#D0D7DD"
                    BorderThickness="1"
                    Padding="14"
                    Margin="0,0,0,15">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Date -->
                    <StackPanel Grid.Column="0" Margin="8,0">
                        <TextBlock Text="التاريخ"
                                   FontWeight="SemiBold"
                                   Foreground="#333"
                                   Margin="0,0,0,6"/>
                        <DatePicker x:Name="BalanceDatePicker"
                                    Height="38"
                                    FontSize="15"/>
                    </StackPanel>

                    <!-- Hint -->
                    <TextBlock Grid.Column="1"
                               Text="اختر تاريخاً لعرض رصيد المخزون حتى نهاية هذا اليوم"
                               VerticalAlignment="Bottom"
                               Foreground="#666"
                               FontSize="13"
                               Margin="8,0,0,2"/>

                    <!-- Buttons -->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Bottom"
                                Margin="8,0">
                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                Width="170"
                                Click="GenerateBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <fa:ImageAwesome Icon="Search" Width="16" Height="16"/>
                                <TextBlock Text=" عرض الرصيد" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Width="120"
                                Margin="10,0,0,0"
                                Click="BackBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <fa:ImageAwesome Icon="ArrowLeft" Width="16" Height="16"/>
                                <TextBlock Text=" رجوع" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- RESULTS GRID -->
            <Border Grid.Row="1"
                    Background="White"
                    CornerRadius="12"
                    BorderBrush="#D0D7DD"
                    BorderThickness="1"
                    Padding="10">

                <DataGrid x:Name="StockBalanceGrid"
                          AutoGenerateColumns="False"
                          Style="{StaticResource MinimalDataGrid}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="كود الصنف" Binding="{Binding ITEMCODE}" Width="140"/>
                        <DataGridTextColumn Header="اسم الصنف" Binding="{Binding ProductName}" Width="280"/>
                        <DataGridTextColumn Header="الوحدة" Binding="{Binding UnitName}" Width="160"/>
                        <DataGridTextColumn Header="الكمية" Binding="{Binding Quantity}" Width="120"/>
                        <DataGridTextColumn Header="الحد الأدنى" Binding="{Binding MinimumQuantity}" Width="140"/>
                        <DataGridTextColumn Header="الحالة" Binding="{Binding StatusText}" Width="160"/>
                    </DataGrid.Columns>
                </DataGrid>

            </Border>
        </Grid>

        <!-- FOOTER -->
        <Border Background="#E3EAF0" Grid.Row="2" Padding="10">
            <TextBlock Text="© 2026 Raccoon Warehouse"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="#2D8DCF"
                       FontWeight="SemiBold"
                       FontSize="14"/>
        </Border>
    </Grid>
</Window>