<Window x:Class="RaccoonWarehouse.Stocks.Reports.InventoryMovementSummary"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        Title="ملخص حركة المخزون"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F2F6FA"
        FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#2D8DCF" Grid.Row="0" Padding="14">
            <TextBlock Text="ملخص حركة المخزون"
                       Foreground="White"
                       FontSize="26"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- FILTERS -->
        <Border Grid.Row="1" Margin="20" Background="White" CornerRadius="12"
                BorderBrush="#D0D7DD" BorderThickness="1" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="8,0">
                    <TextBlock Text="من تاريخ" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <DatePicker x:Name="FromDatePicker" Height="38" FontSize="15"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="8,0">
                    <TextBlock Text="إلى تاريخ" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <DatePicker x:Name="ToDatePicker" Height="38" FontSize="15"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="8,0">
                    <TextBlock Text="الصنف (اختياري)" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <ComboBox x:Name="ProductComboBox" Height="38" FontSize="15"
                              DisplayMemberPath="Name" SelectedValuePath="Id"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="8,0" VerticalAlignment="Bottom">
                    <CheckBox x:Name="IncludeInvoicesCheck"
                              Content="إدراج الفواتير"
                              IsChecked="True"
                              FontSize="14"/>
                </StackPanel>

                <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="8,0">
                    <Button Width="160" Height="38" Click="GenerateBtn_Click"
                            Background="#2D8DCF" Foreground="White" FontWeight="Bold" BorderThickness="0">
                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="File" Width="16" Height="16"/>
                            <TextBlock Text=" عرض التقرير" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Width="120" Height="38" Margin="10,0,0,0" Click="BackBtn_Click"
                            Background="#E3EAF0" Foreground="#2D8DCF" FontWeight="Bold" BorderThickness="0">
                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="ArrowLeft" Width="16" Height="16"/>
                            <TextBlock Text=" رجوع" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- GRID -->
        <Border Grid.Row="2" Margin="20" Background="White" CornerRadius="12"
                BorderBrush="#D0D7DD" BorderThickness="1" Padding="10">
            <DataGrid x:Name="MovementGrid" AutoGenerateColumns="False" IsReadOnly="True"
                      RowHeight="40" ColumnHeaderHeight="44" GridLinesVisibility="None"
                      AlternatingRowBackground="#F7FAFD" FontSize="15">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="كود" Binding="{Binding ITEMCODE}" Width="120"/>
                    <DataGridTextColumn Header="الصنف" Binding="{Binding ProductName}" Width="260"/>
                    <DataGridTextColumn Header="الوحدة" Binding="{Binding UnitName}" Width="140"/>

                    <DataGridTextColumn Header="داخل" Binding="{Binding InQty}" Width="120"/>
                    <DataGridTextColumn Header="خارج" Binding="{Binding OutQty}" Width="120"/>
                    <DataGridTextColumn Header="صافي" Binding="{Binding NetQty}" Width="120"/>

                    <DataGridTextColumn Header="الحد الأدنى" Binding="{Binding MinimumQuantity}" Width="140"/>
                    <DataGridTextColumn Header="الحالة" Binding="{Binding StatusText}" Width="160"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- FOOTER -->
        <Border Background="#E3EAF0" Grid.Row="3" Padding="10">
            <TextBlock Text="© 2025 Raccoon Warehouse"
                       HorizontalAlignment="Center"
                       Foreground="#2D8DCF"
                       FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>