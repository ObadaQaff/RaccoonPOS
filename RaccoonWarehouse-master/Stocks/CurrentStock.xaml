<Window x:Class="RaccoonWarehouse.Stocks.CurrentStock"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        Title="المخزون الحالي"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F2F6FA">

    <Window.Resources>

        <!-- Primary button -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2D8DCF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary button -->
        <Style x:Key="SecondaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#E3EAF0"/>
            <Setter Property="Foreground" Value="#2D8DCF"/>
        </Style>

        <!-- Modern DataGrid -->
        <Style x:Key="MinimalDataGrid" TargetType="DataGrid">
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="ColumnHeaderHeight" Value="44"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="BorderBrush" Value="#D0D7DD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="AlternatingRowBackground" Value="#F7FAFD"/>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#2D8DCF" Grid.Row="0">
            <Grid>
                <TextBlock Text="المخزون الحالي"
                           Foreground="White"
                           FontSize="32"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>

              
            </Grid>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- SEARCH BAR -->
            <StackPanel Orientation="Horizontal"
                        FlowDirection="RightToLeft"
                        VerticalAlignment="Center"
                        Margin="0,10,0,20"
                        HorizontalAlignment="Center">

                <TextBox x:Name="SearchText"
                         Width="300"
                         Height="40"
                         FontSize="18"
                         
                         Padding="10"
                         BorderBrush="#AFC2D3"
                         BorderThickness="1"
                         Background="White"
                         HorizontalContentAlignment="Right"/>

                <Button Style="{StaticResource PrimaryButtonStyle}"
                        Content="بحث"
                        Width="140"
                        Margin="10,0,0,0"
                        Click="SearchBtn_Click"/>

                <Button Style="{StaticResource SecondaryButtonStyle}"
                        Content="تحديث"
                        Width="140"
                        Margin="10,0,0,0"
                        Click="RefreshBtn_Click"/>

                <Button Style="{StaticResource SecondaryButtonStyle}"
                        Content="تصدير Excel"
                        Width="160"
                        Margin="10,0,0,0"
                        Click="ExportBtn_Click"/>
                <Button Style="{StaticResource SecondaryButtonStyle}"
                        Content="رجوع"
                        Width="140"
                        Margin="10,0,0,0"
                        Click="BackBtn_Click"/> 
            </StackPanel>

            <!-- DATA GRID -->
            <Border Grid.Row="1"
                    CornerRadius="12"
                    Background="White"
                    Padding="10"
                    BorderBrush="#D0D7DD"
                    BorderThickness="1">
                <DataGrid x:Name="StockGrid"
                          AutoGenerateColumns="False"
                          Style="{StaticResource MinimalDataGrid}"
                          IsReadOnly="True"
                          ItemsSource="{Binding CurrentStockItems}"
                          FlowDirection="RightToLeft">

                    <DataGrid.Columns>
                        
                        
                        
                        <DataGridTextColumn Header="الباركود"
                        Binding="{Binding ITEMCODE}"
                        Width="200"/>

                        <DataGridTextColumn Header="المنتج"
                                            Binding="{Binding ProductName}"
                                            Width="250"/>

                        <DataGridTextColumn Header="الوحدة"
                                            Binding="{Binding UnitName}"
                                            Width="100"/>

                        <DataGridTextColumn Header="الكمية"
                                            Binding="{Binding Quantity}"
                                            Width="120"/>

                        <DataGridTextColumn Header="الحد الأدنى"
                                            Binding="{Binding MinimumQuantity}"
                                            Width="120"/>

                        <DataGridTemplateColumn Header="تنبيه" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="⚠ قليل"
                                               Foreground="#D9534F"
                                               FontSize="20"
                                               Visibility="{Binding IsLowStock,
                                                    Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>

                </DataGrid>
            </Border>
        </Grid>

        <!-- FOOTER -->
        <Border Background="#E3EAF0" Grid.Row="2">
            <TextBlock Text="© 2025 Raccoon Warehouse"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="#2D8DCF"
                       FontWeight="SemiBold"
                       FontSize="16"/>
        </Border>
    </Grid>
</Window>
