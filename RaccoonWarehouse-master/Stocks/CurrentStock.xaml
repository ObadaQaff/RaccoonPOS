<Window x:Class="RaccoonWarehouse.Stocks.CurrentStock"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        Title="المخزون الحالي"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#EEF3F7"
        FlowDirection="RightToLeft">

    <Window.Resources>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#EEF3F7"/>
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#F8FBFD"/>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D6DEE6"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2F83C5"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#235F90"/>
        <SolidColorBrush x:Key="SoftBrush" Color="#E6EEF5"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#D9534F"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <LinearGradientBrush x:Key="HeroBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#356FA8" Offset="0"/>
            <GradientStop Color="#0F5B52" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{StaticResource SoftBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryDarkBrush}"/>
        </Style>

        <Style x:Key="FilterTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#C7D4E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ReportDataGridStyle" TargetType="DataGrid">
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="ColumnHeaderHeight" Value="46"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E9EEF3"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="BorderBrush" Value="#D6DEE6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FBFD"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="CanUserSortColumns" Value="True"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F1F6FA"/>
                        <Setter Property="Foreground" Value="#27445D"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="BorderBrush" Value="#DDE5EC"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="TextBlock.TextAlignment" Value="Center"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="22,20,22,14"
                CornerRadius="28"
                Padding="24"
                Background="{StaticResource HeroBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#214F77"
                        CornerRadius="20"
                        Padding="16,12"
                        HorizontalAlignment="Left">
                    <StackPanel>
                        <TextBlock Text="المساحة النشطة"
                                   Foreground="#CFE3F3"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="جاهزة"
                                   Foreground="White"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="18,0,0,0"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <TextBlock Text="المخزون الحالي"
                               Foreground="White"
                               FontSize="31"
                               FontWeight="Bold"
                               HorizontalAlignment="Right"/>
                    <TextBlock Text="عرض فوري للأرصدة الحالية مع تنبيه الأصناف القريبة من الحد الأدنى"
                               Foreground="#D3E6F3"
                               FontSize="15"
                               Margin="0,6,0,0"
                               HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="22,0,22,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="22"
                    Padding="18"
                    Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="SearchText"
                             Grid.Column="0"
                             Style="{StaticResource FilterTextBoxStyle}"/>

                    <TextBlock Grid.Column="1"
                               Margin="18,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="#6A7C8E"
                               FontSize="14"
                               Text="ابحث بالباركود أو اسم الصنف ثم حدّث الشبكة أو صدّر النتائج مباشرة."/>

                    <Button Grid.Column="2"
                            Width="118"
                            Margin="12,0,0,0"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="SearchBtn_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <fa:ImageAwesome Icon="Search" Width="15" Height="15"/>
                            <TextBlock Text=" بحث" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="3"
                            Width="118"
                            Margin="12,0,0,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="RefreshBtn_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <fa:ImageAwesome Icon="Refresh" Width="15" Height="15"/>
                            <TextBlock Text=" تحديث" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="4"
                            Width="140"
                            Margin="12,0,0,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="ExportBtn_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <fa:ImageAwesome Icon="Download" Width="15" Height="15"/>
                            <TextBlock Text=" تصدير Excel" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="5"
                            Width="110"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="BackBtn_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <fa:ImageAwesome Icon="ArrowLeft" Width="15" Height="15"/>
                            <TextBlock Text=" رجوع" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="White"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="24"
                    Padding="14">
                <DataGrid x:Name="StockGrid"
                          AutoGenerateColumns="False"
                          Style="{StaticResource ReportDataGridStyle}"
                          ItemsSource="{Binding CurrentStockItems}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="الباركود" Binding="{Binding ITEMCODE}" Width="180"/>
                        <DataGridTextColumn Header="المنتج" Binding="{Binding ProductName}" Width="260"/>
                        <DataGridTextColumn Header="الوحدة" Binding="{Binding UnitName}" Width="120"/>
                        <DataGridTextColumn Header="الكمية" Binding="{Binding Quantity}" Width="120"/>
                        <DataGridTextColumn Header="الحد الأدنى" Binding="{Binding MinimumQuantity}" Width="130"/>
                        <DataGridTemplateColumn Header="تنبيه" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="قليل"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontWeight="Bold"
                                               Visibility="{Binding IsLowStock, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Margin="22,0,22,20"
                Background="#E8EEF3"
                CornerRadius="18"
                Padding="12">
            <TextBlock Text="© 2026 Raccoon Warehouse"
                       HorizontalAlignment="Center"
                       Foreground="#416784"
                       FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>
