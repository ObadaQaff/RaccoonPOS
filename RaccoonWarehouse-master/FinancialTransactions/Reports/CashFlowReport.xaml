<Window x:Class="RaccoonWarehouse.FinancialTransactions.Reports.CashFlowReport"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        Title="تقرير التحصيل والدفع"
        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F2F6FA"
        FlowDirection="RightToLeft">

    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2D8DCF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#E3EAF0"/>
            <Setter Property="Foreground" Value="#2D8DCF"/>
        </Style>

        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CBD5DF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="MinimalDataGrid" TargetType="DataGrid">
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="ColumnHeaderHeight" Value="44"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="BorderBrush" Value="#D0D7DD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="AlternatingRowBackground" Value="#F7FAFD"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
        </Style>

        <Style x:Key="SummaryCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#D0D7DD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="6"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#2D8DCF" Grid.Row="0" Padding="16">
            <TextBlock Text="تقرير التحصيل والدفع"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- FILTER BAR -->
            <Border Background="White" CornerRadius="12" BorderBrush="#D0D7DD" BorderThickness="1"
                    Padding="14" Margin="0,0,0,14">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="210"/>
                        <ColumnDefinition Width="210"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="8,0">
                        <TextBlock Text="من تاريخ" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,6"/>
                        <DatePicker x:Name="FromDatePicker" Height="38" FontSize="15"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="8,0">
                        <TextBlock Text="إلى تاريخ" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,6"/>
                        <DatePicker x:Name="ToDatePicker" Height="38" FontSize="15"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="8,0">
                        <TextBlock Text="الاتجاه" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,6"/>
                        <ComboBox x:Name="DirectionComboBox" Style="{StaticResource ComboStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="8,0">
                        <TextBlock Text="طريقة الدفع" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,6"/>
                        <ComboBox x:Name="PaymentMethodComboBox" Style="{StaticResource ComboStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4" Margin="8,0">
                        <TextBlock Text="مصدر الحركة" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,6"/>
                        <ComboBox x:Name="SourceTypeComboBox" Style="{StaticResource ComboStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="5" Orientation="Horizontal"
                                HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="8,0">
                        <Button Style="{StaticResource PrimaryButtonStyle}" Width="170" Click="GenerateReportBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <fa:ImageAwesome Icon="File" Width="16" Height="16"/>
                                <TextBlock Text=" عرض التقرير" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SecondaryButtonStyle}" Width="120" Margin="10,0,0,0" Click="BackBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <fa:ImageAwesome Icon="ArrowLeft" Width="16" Height="16"/>
                                <TextBlock Text=" رجوع" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- SUMMARY CARDS -->
            <UniformGrid Grid.Row="1" Columns="6" Margin="0,0,0,12">
                <Border Style="{StaticResource SummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="إجمالي القبض" Foreground="#666"/>
                        <TextBlock x:Name="TotalInText" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="إجمالي الصرف" Foreground="#666"/>
                        <TextBlock x:Name="TotalOutText" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="الصافي" Foreground="#666"/>
                        <TextBlock x:Name="NetText" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="عدد الحركات" Foreground="#666"/>
                        <TextBlock x:Name="CountText" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="صافي النقدي" Foreground="#666"/>
                        <TextBlock x:Name="CashNetText" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="صافي الفيزا" Foreground="#666"/>
                        <TextBlock x:Name="VisaNetText" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- GRID -->
            <Border Grid.Row="2" Background="White" CornerRadius="12"
                    BorderBrush="#D0D7DD" BorderThickness="1" Padding="10">

                <DataGrid x:Name="CashFlowGrid" Style="{StaticResource MinimalDataGrid}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="التاريخ" Binding="{Binding Date, StringFormat=yyyy-MM-dd HH:mm}" Width="180"/>
                        <DataGridTextColumn Header="الاتجاه" Binding="{Binding Direction}" Width="110"/>
                        <DataGridTextColumn Header="طريقة الدفع" Binding="{Binding Method}" Width="140"/>

                        <DataGridTextColumn Header="داخل" Binding="{Binding AmountIn}" Width="120"/>
                        <DataGridTextColumn Header="خارج" Binding="{Binding AmountOut}" Width="120"/>
                        <DataGridTextColumn Header="صافي" Binding="{Binding Net}" Width="120"/>

                        <DataGridTextColumn Header="المصدر" Binding="{Binding SourceType}" Width="180"/>
                        <DataGridTextColumn Header="رقم المصدر" Binding="{Binding SourceId}" Width="120"/>
                        <DataGridTextColumn Header="الكاشير" Binding="{Binding CashierName}" Width="160"/>
                        <DataGridTextColumn Header="الحالة" Binding="{Binding StatusText}" Width="110"/>
                        <DataGridTextColumn Header="ملاحظات" Binding="{Binding Notes}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

            </Border>
        </Grid>

        <!-- FOOTER -->
        <Border Background="#E3EAF0" Grid.Row="2" Padding="10">
            <TextBlock Text="© 2025 Raccoon Warehouse"
                       HorizontalAlignment="Center"
                       Foreground="#2D8DCF"
                       FontWeight="SemiBold"
                       FontSize="14"/>
        </Border>
    </Grid>
</Window>