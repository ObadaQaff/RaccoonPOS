<Window x:Class="RaccoonWarehouse.FinancialTransactions.ReceiptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="سند قبض"
        Width="300"
        Height="240"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F6FA"
        WindowStyle="ToolWindow">

    <Grid Margin="8">
        <Border Background="White"
                CornerRadius="10"
                Padding="8"
                BorderBrush="#E0E0E0"
                BorderThickness="1">

            <Grid FlowDirection="RightToLeft">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Header -->
                    <RowDefinition Height="Auto"/>
                    <!-- Amount -->
                    <RowDefinition Height="Auto"/>
                    <!-- Payment Method -->
                    <RowDefinition Height="Auto"/>
                    <!-- Buttons -->
                </Grid.RowDefinitions>

                <!-- 🔵 HEADER -->
                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Transaction Number -->
                    <StackPanel>
                        <TextBlock Text="رقم السند"
                                   FontSize="10"
                                   Foreground="#607D8B"/>
                        <TextBlock Text="{Binding TransactionNumber}"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#263238"/>
                    </StackPanel>

                    <!-- Date -->
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="التاريخ"
                                   FontSize="10"
                                   Foreground="#607D8B"/>
                        <TextBlock Text="{Binding Date}"
                                   FontSize="11"
                                   Foreground="#263238"/>
                    </StackPanel>
                </Grid>

                <!-- 💰 AMOUNT -->
                <StackPanel Grid.Row="1" Margin="0,0,0,6">
                    <TextBlock Text="المبلغ"
                               FontSize="11"
                               FontWeight="SemiBold"/>
                    <TextBox x:Name="AmountTextBox"
                             Height="32"
                             FontSize="16"
                             Margin="0,2,0,0"/>
                </StackPanel>

                <!-- 💳 PAYMENT METHOD -->
                <StackPanel Grid.Row="2" Margin="0,0,0,8">
                    <TextBlock Text="طريقة القبض"
                               FontSize="11"
                               FontWeight="SemiBold"/>
                    <ComboBox x:Name="PaymentMethodCombo"
                              Height="30"
                              FontSize="13"
                              Margin="0,2,0,0"/>
                </StackPanel>

                <!-- 🟢 BUTTONS -->
                <StackPanel Grid.Row="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center">

                    <Button Content="حفظ"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="90"
                            Height="30"
                            Margin="4"
                            Click="Save_Click"/>

                    <Button Content="إلغاء"
                            Style="{StaticResource CancelButtonStyle}"
                            Width="90"
                            Height="30"
                            Margin="4"
                            Click="Cancel_Click"/>
                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</Window>
