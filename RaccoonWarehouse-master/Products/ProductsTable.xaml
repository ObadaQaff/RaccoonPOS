<Window x:Class="RaccoonWarehouse.Products.ProductsTable"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        xmlns:local="clr-namespace:RaccoonWarehouse.Products"
        mc:Ignorable="d"
        Title="جدول الأصناف"
        Height="900"
        Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F2F6FA"
        FlowDirection="RightToLeft">

    <!-- ============== RESOURCES (Like CurrentStock) ============== -->
    <Window.Resources>

        <!-- Primary button -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2D8DCF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary button -->
        <Style x:Key="SecondaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#E3EAF0"/>
            <Setter Property="Foreground" Value="#2D8DCF"/>
        </Style>

        <!-- Search TextBox (matches stock feel) -->
        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderBrush" Value="#AFC2D3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
        </Style>

        <!-- Modern DataGrid -->
        <Style x:Key="MinimalDataGrid" TargetType="DataGrid">
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="ColumnHeaderHeight" Value="44"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="BorderBrush" Value="#D0D7DD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="AlternatingRowBackground" Value="#F7FAFD"/>
        </Style>

    </Window.Resources>

    <!-- ============== LAYOUT ============== -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#2D8DCF" Grid.Row="0">
            <TextBlock Text="جدول الأصناف"
                       Foreground="White"
                       FontSize="32"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="90"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TOP BAR (Search + Actions + Pagination) -->
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        FlowDirection="RightToLeft"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Margin="0,10,0,20">

                <!-- Search by name -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Text="بحث بالاسم:"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#223"/>
                    <TextBox x:Name="SearchByNameTextBox"
                             Width="200"
                             Style="{StaticResource SearchTextBoxStyle}"
                             TextChanged="SearchByNameTextBox_TextChanged"/>
                </StackPanel>

                <!-- Search by barcode -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Text="بحث بالباركود:"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#223"/>
                    <TextBox x:Name="SearchByBarcodeTextBox"
                             Width="200"
                             Style="{StaticResource SearchTextBoxStyle}"
                             TextChanged="SearchByBarcodeTextBox_TextChanged"/>
                </StackPanel>

                <!-- Buttons: Create + Back -->
                <Button x:Name="CreateProductBtn"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="170"
                        Margin="10,0,0,0"
                        Click="CreateProductBtn_Click">
                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="Plus" Width="18" Height="18"
                                         Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        <TextBlock Text="إضافة صنف" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BackBtn"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="120"
                        Margin="10,0,0,0"
                        Click="BackBtn_Click">
                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="ArrowLeft" Width="18" Height="18"
                                         Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        <TextBlock Text="رجوع" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Pagination -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                    <Button x:Name="PrevPageBtn"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="◀ السابق"
                            Width="120"
                            Click="PrevPageBtn_Click"
                            Margin="0,0,10,0"/>
                    <TextBlock x:Name="PageInfoTextBlock"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#223"/>
                    <Button x:Name="NextPageBtn"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="التالي ▶"
                            Width="120"
                            Click="NextPageBtn_Click"/>
                </StackPanel>

            </StackPanel>

            <!-- DATA GRID -->
            <Border Grid.Row="1"
                    CornerRadius="12"
                    Background="White"
                    Padding="10"
                    BorderBrush="#D0D7DD"
                    BorderThickness="1">
                <DataGrid x:Name="ProductsTable1"
                          AutoGenerateColumns="False"
                          ItemsSource="{Binding Products}"
                          Style="{StaticResource MinimalDataGrid}"
                          IsReadOnly="True"
                          FlowDirection="RightToLeft"
                          Margin="0">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="الرقم التعريفي" Binding="{Binding Id}" Width="120"/>
                        <DataGridTextColumn Header="الباركود" Binding="{Binding ITEMCODE}" Width="200"/>
                        <DataGridTextColumn Header="اسم المنتج" Binding="{Binding Name}" Width="250"/>
                        <DataGridTextColumn Header="الفئة الفرعية" Binding="{Binding SubCategory.Name}" Width="170"/>
                        <DataGridTextColumn Header="البراند" Binding="{Binding Brand.Name}" Width="150"/>
                        <DataGridTextColumn Header="السعر الإجمالي" Binding="{Binding ProductUnits[0].SalePrice}" Width="140"/>
                        <DataGridTextColumn Header="التكلفة الحالية" Binding="{Binding ProductUnits[0].PurchasePrice}" Width="140"/>
                        <DataGridTextColumn Header="الكمية للوحدة" Binding="{Binding ProductUnits[0].QuantityPerUnit}" Width="140"/>
                        <DataGridTextColumn Header="تاريخ الإنشاء" Binding="{Binding CreatedDate}" Width="160"/>
                        <DataGridTextColumn Header="آخر تحديث" Binding="{Binding UpdatedDate}" Width="160"/>
                    </DataGrid.Columns>

                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="تعديل" Click="Update_Product"/>
                            <MenuItem Header="حذف" Click="Delete_Product"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>

                </DataGrid>
            </Border>
        </Grid>

        <!-- FOOTER -->
        <Border Background="#E3EAF0" Grid.Row="2">
            <TextBlock Text="© 2025 Raccoon Warehouse"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="#2D8DCF"
                       FontWeight="SemiBold"
                       FontSize="16"/>
        </Border>
    </Grid>
</Window>