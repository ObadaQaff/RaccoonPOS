<Window x:Class="RaccoonWarehouse.Products.ProductsTable"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        mc:Ignorable="d"
        Title="جدول الأصناف"
        Height="900"
        Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{StaticResource AppPageBackgroundBrush}"
        FlowDirection="RightToLeft">
    <Grid Background="{StaticResource AppPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="220"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="0,0,34,34" Background="{StaticResource AppDashboardHeroBrush}">
            <Grid Margin="34,24,34,34">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="إدارة الأصناف" FontSize="34" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
                <Border Grid.Column="1" Padding="18,12" CornerRadius="20" Background="#1FFFFFFF" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="القسم" FontSize="12" Foreground="#CFE8E3" HorizontalAlignment="Center"/>
                        <TextBlock Text="الأصناف" Margin="0,4,0,0" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24,-52,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource AppCardBorderStyle}" Padding="24">
                <StackPanel>
                    <WrapPanel>
                        <Border Width="220" Margin="0,0,12,12" Padding="14,12" Background="#F7FBFD" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" CornerRadius="16">
                            <StackPanel>
                                <TextBlock Text="البحث باسم الصنف" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AppMutedTextBrush}" Margin="0,0,0,8"/>
                                <TextBox x:Name="SearchByNameTextBox"
                                         Style="{StaticResource AppSearchTextBoxStyle}"
                                         TextChanged="SearchByNameTextBox_TextChanged"
                                         ToolTip="ابحث باسم الصنف"/>
                            </StackPanel>
                        </Border>

                        <Border Width="220" Margin="0,0,12,12" Padding="14,12" Background="#F7FBFD" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" CornerRadius="16">
                            <StackPanel>
                                <TextBlock Text="البحث بالباركود" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AppMutedTextBrush}" Margin="0,0,0,8"/>
                                <TextBox x:Name="SearchByBarcodeTextBox"
                                         Style="{StaticResource AppSearchTextBoxStyle}"
                                         TextChanged="SearchByBarcodeTextBox_TextChanged"
                                         ToolTip="ابحث بالباركود"/>
                            </StackPanel>
                        </Border>

                        <Button x:Name="CreateProductBtn" Width="170" Height="50" Margin="0,0,12,12" Style="{StaticResource AppHeroButtonStyle}" Click="CreateProductBtn_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <fa:ImageAwesome Icon="Plus" Width="16" Height="16" Margin="0,0,8,0" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="إضافة صنف"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="BackBtn" Width="120" Height="50" Margin="0,0,12,12" Style="{StaticResource AppSecondaryButtonStyle}" Click="BackBtn_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <fa:ImageAwesome Icon="ArrowRight" Width="16" Height="16" Margin="0,0,8,0" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="رجوع"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="PrevPageBtn" Width="120" Height="50" Margin="0,0,12,12" Style="{StaticResource AppSecondaryButtonStyle}" Content="السابق" Click="PrevPageBtn_Click"/>
                        <Button x:Name="NextPageBtn" Width="120" Height="50" Margin="0,0,12,12" Style="{StaticResource AppSecondaryButtonStyle}" Content="التالي" Click="NextPageBtn_Click"/>
                    </WrapPanel>

                    <TextBlock x:Name="PageInfoTextBlock"
                               Margin="0,8,0,0"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AppMutedTextBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Margin="0,18,0,0" Style="{StaticResource AppCardBorderStyle}" Padding="16">
                <DataGrid x:Name="ProductsTable1"
                          AutoGenerateColumns="False"
                          ItemsSource="{Binding Products}"
                          Style="{StaticResource AppModernDataGridStyle}"
                          IsReadOnly="True"
                          FlowDirection="RightToLeft">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="الرقم التعريفي" Binding="{Binding Id}" Width="120"/>
                        <DataGridTextColumn Header="الباركود" Binding="{Binding ITEMCODE}" Width="200"/>
                        <DataGridTextColumn Header="اسم المنتج" Binding="{Binding Name}" Width="250"/>
                        <DataGridTextColumn Header="الفئة الفرعية" Binding="{Binding SubCategory.Name}" Width="170"/>
                        <DataGridTextColumn Header="البراند" Binding="{Binding Brand.Name}" Width="150"/>
                        <DataGridTextColumn Header="سعر البيع" Binding="{Binding DefaultSalePrice}" Width="140"/>
                        <DataGridTextColumn Header="سعر الشراء" Binding="{Binding DefaultPurchasePrice}" Width="140"/>
                        <DataGridTextColumn Header="كمية الوحدة الأساسية" Binding="{Binding BaseQuantityPerUnit}" Width="160"/>
                        <DataGridTextColumn Header="تاريخ الإنشاء" Binding="{Binding CreatedDate}" Width="160"/>
                        <DataGridTextColumn Header="آخر تحديث" Binding="{Binding UpdatedDate}" Width="160"/>
                    </DataGrid.Columns>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Style="{StaticResource AppMenuItemStyle}" Header="تعديل" Click="Update_Product"/>
                            <MenuItem Style="{StaticResource AppMenuItemStyle}" Header="حذف" Click="Delete_Product"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Window>
