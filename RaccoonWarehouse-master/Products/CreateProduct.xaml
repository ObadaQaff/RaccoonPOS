<Window x:Class="RaccoonWarehouse.Products.CreateProduct"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="بطاقة إدخال صنف"
        Height="900"
        Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F7F8FA"
        FlowDirection="RightToLeft">

    <!-- ============== RESOURCES ============== -->
    <Window.Resources>
        <!-- Buttons -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3396D3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBCB90"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FFF0CE"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#3396D3"/>
            <Setter Property="BorderBrush" Value="#3396D3"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>

        <!-- Inputs -->
        <Style x:Key="InputBoxStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputComboStyle" TargetType="ComboBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"/>
                            <ToggleButton x:Name="ToggleButton"
                                  Grid.Column="2"
                                  Focusable="False"
                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                  Background="Transparent"
                                  BorderBrush="Transparent"
                                  ClickMode="Press"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Stretch">
                                <Path x:Name="Arrow"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Data="M 0 0 L 4 4 L 8 0 Z"
                              Fill="#666"
                              Width="8"
                              Height="6"/>
                            </ToggleButton>
                            <ContentPresenter Margin="8,0,25,0"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Right"
                                      Content="{TemplateBinding SelectionBoxItem}"
                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                      RecognizesAccessKey="True"/>
                            <Popup x:Name="Popup"
                           Placement="Bottom"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           AllowsTransparency="True"
                           Focusable="False"
                           PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder"
                                Background="White"
                                BorderBrush="#D0D0D0"
                                BorderThickness="1"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                                    <ScrollViewer Margin="4,2,4,2"
                                          SnapsToDevicePixels="True"
                                          CanContentScroll="True">
                                        <StackPanel IsItemsHost="True"
                                            KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#3396D3"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ============== LAYOUT ============== -->
    <Grid Background="#F7F8FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="55"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="45"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#3396D3" Grid.Row="0" CornerRadius="0,0,12,12">
            <TextBlock Text="بطاقة إدخال صنف"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="1" Padding="0,20">
            <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" Width="900">

                <!-- Row 1 -->
                <UniformGrid Columns="3" Margin="0,0,0,10">
                    <StackPanel Margin="8,0">
                        <TextBlock Text="اسم الصنف" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,4"/>
                        <TextBox x:Name="NameTextBox" Style="{StaticResource InputBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Margin="8,0">
                        <TextBlock Text="الكود / الباركود" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,4"/>
                        <TextBox x:Name="ITEMCODE" Style="{StaticResource InputBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Margin="8,0">
                        <TextBlock Text="الحالة" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,4"/>
                        <ComboBox x:Name="StatusComboBox" Style="{StaticResource InputComboStyle}"/>
                    </StackPanel>
                </UniformGrid>

                <!-- Row 2 -->
                <UniformGrid Columns="3" Margin="0,0,0,10">
                    <StackPanel Margin="8,0">
                        <TextBlock Text="العالمة التجارية" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,4"/>
                        <ComboBox x:Name="BrandComboBox" Style="{StaticResource InputComboStyle}"/>
                    </StackPanel>

                    <StackPanel Margin="8,0">
                        <TextBlock Text="الفئة الفرعية" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,4"/>
                        <ComboBox x:Name="SubCategoryComboBox" Style="{StaticResource InputComboStyle}"/>
                    </StackPanel>

                    <StackPanel Margin="8,0">
                        <TextBlock Text="الكمية الدنيا" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,4"/>
                        <TextBox x:Name="MinimumQuantityTextBox" Style="{StaticResource InputBoxStyle}"/>
                    </StackPanel>
                </UniformGrid>

                <!-- Description + Tax -->
                <StackPanel Margin="8,0,8,10">

                    <TextBlock Text="الوصف"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#333"
                           Margin="0,0,0,4"/>       

                    <TextBox x:Name="DescriptionTextBox"
                            Style="{StaticResource InputBoxStyle}"
                            Height="60"
                            AcceptsReturn="True"
                            TextWrapping="Wrap"/>  

                    <!-- Tax row -->
                    <Grid Margin="0,8,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox x:Name="TaxExemptCheckBox"
                                  Grid.Column="0"
                                  Content="معفى من الضريبة"
                                  FontSize="13"
                                  VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="2"
                               Text="نسبة الضريبة"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#333"
                               VerticalAlignment="Center"/>

                        <TextBox x:Name="TaxRate"
                             Grid.Column="3" 
                             FlowDirection="RightToLeft"
                             Style="{StaticResource InputBoxStyle}"
                             Margin="10,0,531,0"/>
                    </Grid>

                </StackPanel>


                <!-- Units Section -->
                <TextBlock Text="الوحدات والأسعار" FontSize="16" FontWeight="Bold" Foreground="#444" Margin="0,10,0,8"/>

                <UniformGrid Columns="4" Margin="0,0,0,10">
                    <StackPanel Margin="6,0">
                        <TextBlock Text="الوحدة" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,4"/>
                        <ComboBox x:Name="UnitComboBox" Style="{StaticResource InputComboStyle}" />
                    </StackPanel>

                    <StackPanel Margin="6,0">
                        <TextBlock Text="سعر البيع" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,4"/>
                        <TextBox x:Name="SalePriceTextBox" Style="{StaticResource InputBoxStyle}" />
                    </StackPanel>

                    <StackPanel Margin="6,0">
                        <TextBlock Text="سعر الشراء" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,4"/>
                        <TextBox x:Name="PurchasePriceTextBox" Style="{StaticResource InputBoxStyle}" />
                    </StackPanel>

                    <StackPanel Margin="6,0">
                        <TextBlock Text="الكمية لكل وحدة" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,4"/>
                        <TextBox x:Name="QuantityPerUnitTextBox" Style="{StaticResource InputBoxStyle}" />
                    </StackPanel>
                </UniformGrid>

                <!-- Add Unit Button -->
                <Button Content="➕ إضافة وحدة" 
                        Width="200"
                        Style="{StaticResource PrimaryButtonStyle}" 
                        HorizontalAlignment="Center" 
                        Margin="0,10,0,20" 
                        Click="AddUnit_Click"/>

                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Button Content="عودة" Style="{StaticResource SecondaryButtonStyle}" Width="160" Click="Button_Click_2" Margin="0,0,10,0"/>
                    <Button Content="حفظ" Style="{StaticResource PrimaryButtonStyle}" Width="160" Click="Button_Click_1"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- FOOTER -->
        <Border Background="#FFF0CE" Grid.Row="2">
            <TextBlock Text="© 2025 Raccoon Warehouse"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="#3396D3"
                       FontSize="12"
                       FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>
