<Window x:Class="RaccoonWarehouse.Products.CreateProduct"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="بطاقة إدخال صنف"
        Height="900"
        Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{StaticResource AppPageBackgroundBrush}"
        FlowDirection="RightToLeft">
    <Grid Background="{StaticResource AppPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="220"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" CornerRadius="0,0,34,34" Background="{StaticResource AppDashboardHeroBrush}">
            <Grid Margin="34,24,34,34">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="بطاقة إدخال صنف" FontSize="34" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
            </Grid>
        </Border>
        <Grid Grid.Row="1" Margin="24,-52,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.6*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource AppCardBorderStyle}" Padding="24" Margin="0,0,20,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <UniformGrid Columns="3" Margin="0,0,0,10">
                            <StackPanel Margin="8,0">
                                <TextBlock Text="اسم الصنف" Style="{StaticResource AppFieldLabelStyle}"/>
                                <TextBox x:Name="NameTextBox" Style="{StaticResource AppTextInputStyle}"/>
                            </StackPanel>
                            <StackPanel Margin="8,0">
                                <TextBlock Text="الكود / الباركود" Style="{StaticResource AppFieldLabelStyle}"/>
                                <TextBox x:Name="ITEMCODE" Style="{StaticResource AppTextInputStyle}"/>
                            </StackPanel>
                            <StackPanel Margin="8,0">
                                <TextBlock Text="الحالة" Style="{StaticResource AppFieldLabelStyle}"/>
                                <ComboBox x:Name="StatusComboBox" Style="{StaticResource AppComboBoxStyle}"/>
                            </StackPanel>
                        </UniformGrid>
                        <UniformGrid Columns="3" Margin="0,0,0,10">
                            <StackPanel Margin="8,0">
                                <TextBlock Text="العلامة التجارية" Style="{StaticResource AppFieldLabelStyle}"/>
                                <ComboBox x:Name="BrandComboBox" Style="{StaticResource AppComboBoxStyle}"/>
                            </StackPanel>
                            <StackPanel Margin="8,0">
                                <TextBlock Text="الفئة الفرعية" Style="{StaticResource AppFieldLabelStyle}"/>
                                <ComboBox x:Name="SubCategoryComboBox" Style="{StaticResource AppComboBoxStyle}"/>
                            </StackPanel>
                            <StackPanel Margin="8,0">
                                <TextBlock Text="الكمية الدنيا" Style="{StaticResource AppFieldLabelStyle}"/>
                                <TextBox x:Name="MinimumQuantityTextBox" Style="{StaticResource AppTextInputStyle}"/>
                            </StackPanel>
                        </UniformGrid>
                        <StackPanel Margin="8,0,8,10">
                            <TextBlock Text="الوصف" Style="{StaticResource AppFieldLabelStyle}"/>
                            <TextBox x:Name="DescriptionTextBox" Style="{StaticResource AppTextInputStyle}" Height="72" AcceptsReturn="True" TextWrapping="Wrap"/>
                            <Grid Margin="0,8,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox x:Name="TaxExemptCheckBox" Grid.Column="0" Content="معفى من الضريبة" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="نسبة الضريبة" Style="{StaticResource AppFieldLabelStyle}" VerticalAlignment="Center" Margin="0"/>
                                <TextBox x:Name="TaxRate" Grid.Column="3" Style="{StaticResource AppTextInputStyle}" Margin="10,0,0,0"/>
                            </Grid>
                        </StackPanel>
                        <TextBlock Text="الوحدات والأسعار" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AppTextBrush}" Margin="0,10,0,8"/>
                        <UniformGrid Columns="7" Margin="0,0,0,10">
                            <StackPanel Margin="6,0">
                                <TextBlock Text="الوحدة" Style="{StaticResource AppFieldLabelStyle}"/>
                                <ComboBox x:Name="UnitComboBox" Style="{StaticResource AppComboBoxStyle}" />
                            </StackPanel>
                            <StackPanel Margin="6,0">
                                <TextBlock Text="سعر البيع" Style="{StaticResource AppFieldLabelStyle}"/>
                                <TextBox x:Name="SalePriceTextBox" Style="{StaticResource AppTextInputStyle}" />
                            </StackPanel>
                            <StackPanel Margin="6,0">
                                <TextBlock Text="سعر الشراء" Style="{StaticResource AppFieldLabelStyle}"/>
                                <TextBox x:Name="PurchasePriceTextBox" Style="{StaticResource AppTextInputStyle}" />
                            </StackPanel>
                            <StackPanel Margin="6,0">
                                <TextBlock Text="الكمية لكل وحدة" Style="{StaticResource AppFieldLabelStyle}"/>
                                <TextBox x:Name="QuantityPerUnitTextBox" Style="{StaticResource AppTextInputStyle}" />
                            </StackPanel>
                            <StackPanel Margin="6,0">
                                <TextBlock Text="أساسية" Style="{StaticResource AppFieldLabelStyle}"/>
                                <CheckBox x:Name="IsBaseUnitCheckBox" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Margin="6,0">
                                <TextBlock Text="افتراضي بيع" Style="{StaticResource AppFieldLabelStyle}"/>
                                <CheckBox x:Name="IsDefaultSaleUnitCheckBox" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Margin="6,0">
                                <TextBlock Text="افتراضي شراء" Style="{StaticResource AppFieldLabelStyle}"/>
                                <CheckBox x:Name="IsDefaultPurchaseUnitCheckBox" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </UniformGrid>
                        <TextBlock Text="الوحدات المضافة" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AppTextBrush}" Margin="0,10,0,8"/>
                        <StackPanel x:Name="UnitsStackPanel" Margin="8,0,8,10"/>
                        <Button Content="إضافة وحدة" Width="200" Style="{StaticResource AppFormButtonStyle}" HorizontalAlignment="Center" Margin="0,10,0,20" Click="AddUnit_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource AppCardBorderStyle}" Padding="24">
                <StackPanel>
                    <TextBlock Text="إجراءات" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AppPrimaryBrush}"/>
                    <TextBlock Margin="0,12,0,0" FontSize="14" Foreground="{StaticResource AppMutedTextBrush}" Text="أدخل البيانات الأساسية ووحدات السعر ثم احفظ الصنف الجديد."/>
                    <Button Content="حفظ" Margin="0,34,0,0" Width="160" Style="{StaticResource AppFormButtonStyle}" Click="Button_Click_1"/>
                    <Button Content="عودة" Margin="0,14,0,0" Width="160" Style="{StaticResource AppSecondaryButtonStyle}" Click="Button_Click_2"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
