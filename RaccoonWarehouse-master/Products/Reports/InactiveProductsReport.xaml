<Window x:Class="RaccoonWarehouse.Products.Reports.InactiveProductsReport"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تقرير الأصناف غير المتحركة"
        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F2F6FA"
        FlowDirection="RightToLeft">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <TextBlock Text="تقرير الأصناف غير المتحركة"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="#2D8DCF"
                   HorizontalAlignment="Center"/>

        <!-- FILTER BAR -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,20,0,20">

            <StackPanel Margin="10,0">
                <TextBlock Text="عدد الأيام بدون حركة"/>
                <TextBox x:Name="DaysTextBox" Width="100" Height="35" Text="30"/>
            </StackPanel>

            <StackPanel Margin="10,0">
                <TextBlock Text="تاريخ حتى"/>
                <DatePicker x:Name="AsOfDatePicker" Height="35"/>
            </StackPanel>

            <CheckBox x:Name="ZeroStockCheck"
                      Content="فقط أصناف بدون رصيد"
                      VerticalAlignment="Bottom"
                      Margin="20,0"/>

            <Button Content="عرض التقرير"
                    Width="150"
                    Height="40"
                    Margin="30,0"
                    Click="GenerateReportBtn_Click"
                    Background="#2D8DCF"
                    Foreground="White"
                    FontWeight="Bold"/>

        </StackPanel>

        <!-- GRID -->
        <DataGrid x:Name="InactiveGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  FontSize="14">

            <DataGrid.Columns>
                <DataGridTextColumn Header="كود" Binding="{Binding ITEMCODE}" Width="120"/>
                <DataGridTextColumn Header="الصنف" Binding="{Binding ProductName}" Width="300"/>
                <DataGridTextColumn Header="الرصيد الحالي" Binding="{Binding CurrentStock}" Width="140"/>
                <DataGridTextColumn Header="الحد الأدنى" Binding="{Binding MinimumQuantity}" Width="140"/>
                <DataGridTextColumn Header="آخر حركة" Binding="{Binding LastMovementDate, StringFormat=yyyy-MM-dd}" Width="150"/>
                <DataGridTextColumn Header="أيام بدون حركة" Binding="{Binding DaysSinceLastMovement}" Width="160"/>
                <DataGridTextColumn Header="الحالة" Binding="{Binding StatusText}" Width="140"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>