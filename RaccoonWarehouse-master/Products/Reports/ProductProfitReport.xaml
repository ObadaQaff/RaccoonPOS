<Window x:Class="RaccoonWarehouse.Products.Reports.ProductProfitReport"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        Title="تقرير أرباح الأصناف"
        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F2F6FA"
        FlowDirection="RightToLeft">

    <Window.Resources>

        <!-- Primary button -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2D8DCF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary button -->
        <Style x:Key="SecondaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#E3EAF0"/>
            <Setter Property="Foreground" Value="#2D8DCF"/>
        </Style>

        <!-- Combo -->
        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CBD5DF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- DataGrid -->
        <Style x:Key="MinimalDataGrid" TargetType="DataGrid">
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="ColumnHeaderHeight" Value="44"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="BorderBrush" Value="#D0D7DD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="AlternatingRowBackground" Value="#F7FAFD"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
        </Style>

        <!-- Summary card -->
        <Style x:Key="SummaryCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#D0D7DD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="6"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#2D8DCF" Grid.Row="0" Padding="16">
            <TextBlock Text="تقرير أرباح الأصناف"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- FILTER BAR -->
            <Border Background="White"
                    CornerRadius="12"
                    BorderBrush="#D0D7DD"
                    BorderThickness="1"
                    Padding="14"
                    Margin="0,0,0,14">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="210"/>
                        <ColumnDefinition Width="210"/>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- From -->
                    <StackPanel Grid.Column="0" Margin="8,0">
                        <TextBlock Text="من تاريخ" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,6"/>
                        <DatePicker x:Name="FromDatePicker" Height="38" FontSize="15"/>
                    </StackPanel>

                    <!-- To -->
                    <StackPanel Grid.Column="1" Margin="8,0">
                        <TextBlock Text="إلى تاريخ" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,6"/>
                        <DatePicker x:Name="ToDatePicker" Height="38" FontSize="15"/>
                    </StackPanel>

                    <!-- Product (optional filter) -->
                    <StackPanel Grid.Column="2" Margin="8,0">
                        <TextBlock Text="الصنف (اختياري)" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,6"/>
                        <ComboBox x:Name="ProductComboBox"
                                  Style="{StaticResource ComboStyle}"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"/>
                    </StackPanel>

                    <!-- Include Returns -->
                    <StackPanel Grid.Column="3" Margin="8,0" VerticalAlignment="Bottom">
                        <CheckBox x:Name="IncludeReturnsCheckBox"
                                  Content="إدراج المرتجعات"
                                  FontSize="14"
                                  IsChecked="True"/>
                    </StackPanel>

                    <!-- Group By Unit -->
                    <StackPanel Grid.Column="4" Margin="8,0" VerticalAlignment="Bottom">
                        <CheckBox x:Name="GroupByUnitCheckBox"
                                  Content="تجميع حسب الوحدة"
                                  FontSize="14"
                                  IsChecked="False"/>
                    </StackPanel>

                    <!-- Buttons -->
                    <StackPanel Grid.Column="5"
                                Orientation="Horizontal"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Bottom"
                                Margin="8,0">

                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                Width="170"
                                Click="GenerateReportBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <fa:ImageAwesome Icon="File" Width="16" Height="16"/>
                                <TextBlock Text=" عرض التقرير" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Width="120"
                                Margin="10,0,0,0"
                                Click="BackBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <fa:ImageAwesome Icon="ArrowLeft" Width="16" Height="16"/>
                                <TextBlock Text=" رجوع" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- SUMMARY CARDS -->
            <UniformGrid Grid.Row="1" Columns="6" Margin="0,0,0,12">
                <Border Style="{StaticResource SummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="صافي المبيعات" Foreground="#666"/>
                        <TextBlock x:Name="NetSalesText" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="الضريبة" Foreground="#666"/>
                        <TextBlock x:Name="TotalTaxText" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="الخصم" Foreground="#666"/>
                        <TextBlock x:Name="TotalDiscountText" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="COGS" Foreground="#666"/>
                        <TextBlock x:Name="TotalCogsText" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="الربح الإجمالي" Foreground="#666"/>
                        <TextBlock x:Name="GrossProfitText" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="الهامش %" Foreground="#666"/>
                        <TextBlock x:Name="MarginText" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- RESULTS GRID -->
            <Border Grid.Row="2"
                    Background="White"
                    CornerRadius="12"
                    BorderBrush="#D0D7DD"
                    BorderThickness="1"
                    Padding="10">

                <DataGrid x:Name="ProductProfitGrid"
                          Style="{StaticResource MinimalDataGrid}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="كود" Binding="{Binding ITEMCODE}" Width="110"/>
                        <DataGridTextColumn Header="الصنف" Binding="{Binding ProductName}" Width="260"/>
                        <DataGridTextColumn Header="الوحدة" Binding="{Binding UnitName}" Width="140"/>
                        <DataGridTextColumn Header="الكمية" Binding="{Binding SalesQty}" Width="120"/>
                        <DataGridTextColumn Header="قبل الضريبة" Binding="{Binding SubTotal}" Width="150"/>
                        <DataGridTextColumn Header="الخصم" Binding="{Binding Discount}" Width="140"/>
                        <DataGridTextColumn Header="صافي المبيعات" Binding="{Binding NetSales}" Width="150"/>
                        <DataGridTextColumn Header="الضريبة" Binding="{Binding Tax}" Width="130"/>
                        <DataGridTextColumn Header="COGS" Binding="{Binding COGS}" Width="140"/>
                        <DataGridTextColumn Header="الربح" Binding="{Binding GrossProfit}" Width="140"/>
                        <DataGridTextColumn Header="الهامش %" Binding="{Binding Margin}" Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>

            </Border>
        </Grid>

        <!-- FOOTER -->
        <Border Background="#E3EAF0" Grid.Row="2" Padding="10">
            <TextBlock Text="© 2025 Raccoon Warehouse"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="#2D8DCF"
                       FontWeight="SemiBold"
                       FontSize="14"/>
        </Border>
    </Grid>
</Window>