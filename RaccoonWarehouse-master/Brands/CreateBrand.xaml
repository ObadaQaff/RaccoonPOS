<Window x:Class="RaccoonWarehouse.Brands.CreateBrand"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        xmlns:local="clr-namespace:RaccoonWarehouse.Units"
        mc:Ignorable="d"
        Title="إنشاء علامة تجارية"
        Height="800"
        Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <!-- ============== RESOURCES ============== -->
    <Window.Resources>
        <!-- Primary button style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3396D3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="15,8"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBCB90"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FFF0CE"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary button style -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#FFF0CE"/>
            <Setter Property="Foreground" Value="#3396D3"/>
        </Style>
    </Window.Resources>

    <!-- ============== LAYOUT ============== -->
    <Grid Background="#EEEEEE">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="70"/>
            <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#3396D3" Grid.Row="0">
            <TextBlock Text="إنشاء علامة تجارية"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- CONTENT -->
        <StackPanel Grid.Row="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="800"
                    FlowDirection="RightToLeft">

            <!-- Category Name -->
            <TextBlock Text="إسم العلامة التجارية"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#333"
                       Margin="0,0,0,5"/>
            <TextBox x:Name="Name"
                     Height="44"
                     FontSize="18"
                     Background="White"
                     BorderBrush="#EBCB90"
                     BorderThickness="1"
                     Padding="8"
                     Margin="0,0,0,20"/>

            <!-- Category ImageUrl -->
            <TextBlock Text="الصورة "
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#333"
                       Margin="0,0,0,5"/>
            <TextBox x:Name="ImageUrl"
                     Height="44"
                     FontSize="18"
                     Background="White"
                     BorderBrush="#EBCB90"
                     BorderThickness="1"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     Padding="8"
                     Margin="0,0,0,20"/>

            <!-- Action Buttons -->
            <StackPanel Orientation="Horizontal"
                        FlowDirection="RightToLeft"
                        HorizontalAlignment="Center"
                        Margin="0,20,0,0">
                <Button x:Name="BackBtn"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="200"
                        Click="Button_Click"
                        Margin="0,0,20,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <fa:ImageAwesome Icon="ArrowLeft" Width="18" Height="18"
                                         Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        <TextBlock Text=" عودة" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>

                <Button x:Name="CreateBrandBtn"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="200"
                        Click="Button_Click_1">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <fa:ImageAwesome Icon="Plus" Width="18" Height="18"
                                         Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        <TextBlock Text=" إنشاء" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>

        <!-- FOOTER -->
        <Border Background="#FFF0CE" Grid.Row="2">
            <TextBlock Text="© 2025 Raccoon Warehouse"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="#3396D3"
                       FontSize="14"
                       FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>