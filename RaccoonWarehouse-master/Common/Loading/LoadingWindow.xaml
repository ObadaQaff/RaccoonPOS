<Window x:Class="RaccoonWarehouse.Common.Loading.LoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Width="420"
        Height="260"
        ShowInTaskbar="False">

    <Grid>
        <!-- Card -->
        <Border Background="#263238"
                CornerRadius="20"
                Padding="28"
                Width="360"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center" Height="186" Width="213">

                <!-- 🦝 LOGO -->
                <Image Source="pack://application:,,,/Assets/Logo/Logo newfinal.png"
                       Width="60"
                       Height="50"
                       Margin="0,0,0,0"
                       />

                <!-- APP NAME -->
                <TextBlock Text="Raccoon Warehouse"
                   FontSize="22"
                   FontWeight="SemiBold"
                   FontFamily="Segoe UI Variable"
                   Foreground="White"
                   Margin="0,6,0,18"
                   HorizontalAlignment="Center"/>

                <!-- 🔄 SPINNER -->
                <Grid Width="48"
                      Height="48"
                      Margin="0,0,0,14">
                    <Ellipse Stroke="#455A64"
                             StrokeThickness="4"/>

                    <Ellipse Stroke="#FFFFFF"
                             StrokeThickness="4"
                             StrokeDashArray="2 6"
                             StrokeStartLineCap="Round"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform/>
                        </Ellipse.RenderTransform>

                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="(Ellipse.RenderTransform).(RotateTransform.Angle)"
                                            From="0"
                                            To="360"
                                            Duration="0:0:1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                </Grid>

                <!-- MESSAGE -->
                <TextBlock x:Name="MessageText"
                   Text="Loading, please wait..."
                   FontSize="14"
                   FontWeight="Medium"
                   FontFamily="Segoe UI Variable"
                   Foreground="#CFD8DC"
                   HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
