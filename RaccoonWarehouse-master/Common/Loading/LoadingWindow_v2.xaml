<Window x:Class="RaccoonWarehouse.Common.Loading.LoadingWindow_v2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="#80000000"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Width="320"
        Height="200">

    <Grid>
        <!-- Card -->
        <Border Background="White"
                CornerRadius="16"
                Padding="20"
                Width="280"
                Height="160"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Effect="{StaticResource DropShadowSoft}">

            
            
            
            <StackPanel HorizontalAlignment="Center">

                <!-- 🔵 LOGO -->
                <Image Source="pack://application:,,,/Assets/logo/Logo newfinal.ico"
                   Width="70"
                   Height="36"
                   Margin="0,0,0,12" RenderTransformOrigin="0.402,0.657"/>

                <!-- 🔄 CIRCULAR LOADER -->
                <Grid Width="40" Height="40" Margin="0,0,0,12">
                    <Ellipse Stroke="#E0E0E0"
                             StrokeThickness="4"/>

                    <Ellipse Stroke="#263238"
                             StrokeThickness="4"
                             StrokeDashArray="2 6"
                             StrokeStartLineCap="Round"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform/>
                        </Ellipse.RenderTransform>

                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="(Ellipse.RenderTransform).(RotateTransform.Angle)"
                                            From="0"
                                            To="360"
                                            Duration="0:0:1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                </Grid>

                <!-- 📝 MESSAGE -->
                <TextBlock x:Name="MessageText"
                           Text="جاري المعالجة..."
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#263238"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
