<Window x:Class="RaccoonWarehouse.Warehouses.WarehousesTable"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="جدول المستودعات"
        Height="800"
        Width="1400"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="{StaticResource AppPageBackgroundBrush}">
    <Grid Background="{StaticResource AppPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="220"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" CornerRadius="0,0,34,34" Background="{StaticResource AppDashboardHeroBrush}">
            <Grid Margin="34,24,34,34">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="إدارة المستودعات" FontSize="34" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
                <Border Grid.Column="1" Padding="18,12" CornerRadius="20" Background="#1FFFFFFF" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="القسم" FontSize="12" Foreground="#CFE8E3" HorizontalAlignment="Center"/>
                        <TextBlock Text="المستودعات" Margin="0,4,0,0" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        <Grid Grid.Row="1" Margin="24,-52,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Style="{StaticResource AppCardBorderStyle}" Padding="24">
                <StackPanel>
                    <TextBlock Text="البحث بالاسم" Style="{StaticResource AppFieldLabelStyle}"/>
                    <TextBox x:Name="SearchBox" Width="420" Style="{StaticResource AppSearchTextBoxStyle}" TextChanged="SearchBox_TextChanged"/>
                </StackPanel>
            </Border>
            <Border Grid.Row="1" Margin="0,18,0,0" Style="{StaticResource AppCardBorderStyle}" Padding="16">
                <DataGrid x:Name="WarehousesGrid"
                          Style="{StaticResource AppModernDataGridStyle}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="الرقم" Binding="{Binding Id}" Width="100"/>
                        <DataGridTextColumn Header="اسم المستودع" Binding="{Binding Name}" Width="200"/>
                        <DataGridTextColumn Header="الموقع" Binding="{Binding Location}" Width="200"/>
                        <DataGridTextColumn Header="الوصف" Binding="{Binding Description}" Width="300"/>
                        <DataGridTextColumn Header="رقم الهاتف" Binding="{Binding PhoneNumber}" Width="150"/>
                        <DataGridTextColumn Header="الحالة" Binding="{Binding Status}" Width="150"/>
                        <DataGridTextColumn Header="تاريخ الإنشاء" Binding="{Binding CreatedDate}" Width="200"/>
                        <DataGridTextColumn Header="تاريخ التعديل" Binding="{Binding UpdatedDate}" Width="200"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Window>
