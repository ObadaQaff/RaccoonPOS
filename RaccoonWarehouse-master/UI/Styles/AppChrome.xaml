<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="AppPageBackgroundBrush" Color="#EEF2F5"/>
    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#FFFDFC"/>
    <SolidColorBrush x:Key="AppPanelSoftBrush" Color="#F5F8FA"/>
    <SolidColorBrush x:Key="AppBorderBrush" Color="#D7E0E7"/>
    <SolidColorBrush x:Key="AppMutedTextBrush" Color="#61717D"/>
    <SolidColorBrush x:Key="AppTextBrush" Color="#203442"/>
    <SolidColorBrush x:Key="AppPrimaryBrush" Color="#145A4A"/>
    <SolidColorBrush x:Key="AppPrimaryDarkBrush" Color="#0F4A3E"/>
    <SolidColorBrush x:Key="AppBlueBrush" Color="#134B70"/>
    <SolidColorBrush x:Key="AppBlueDarkBrush" Color="#103E5B"/>
    <SolidColorBrush x:Key="AppAccentBrush" Color="#F2C46D"/>
    <SolidColorBrush x:Key="AppSidebarBrush" Color="#22343C"/>
    <SolidColorBrush x:Key="AppSidebarHoverBrush" Color="#2E4954"/>
    <SolidColorBrush x:Key="AppSidebarTextBrush" Color="#F7FAFB"/>

    <LinearGradientBrush x:Key="AppGreenHeroBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0F4A3E" Offset="0"/>
        <GradientStop Color="#145A4A" Offset="0.55"/>
        <GradientStop Color="#20806B" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AppBlueHeroBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#103E5B" Offset="0"/>
        <GradientStop Color="#134B70" Offset="0.55"/>
        <GradientStop Color="#1E658C" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AppDashboardHeroBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1B2E36" Offset="0"/>
        <GradientStop Color="#145A4A" Offset="0.58"/>
        <GradientStop Color="#134B70" Offset="1"/>
    </LinearGradientBrush>

    <Style x:Key="AppHeroButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="48"/>
        <Setter Property="Padding" Value="18,0"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FlowDirection" Value="RightToLeft"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Background" Value="{StaticResource AppPrimaryBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource AppPrimaryDarkBrush}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.55"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="AppSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource AppHeroButtonStyle}">
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
    </Style>

    <Style x:Key="AppFormButtonStyle" TargetType="Button" BasedOn="{StaticResource AppHeroButtonStyle}">
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style x:Key="AppFieldLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#243746"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="FlowDirection" Value="RightToLeft"/>
        <Setter Property="TextAlignment" Value="Right"/>
    </Style>

    <Style x:Key="AppTextInputStyle" TargetType="TextBox">
        <Setter Property="Height" Value="54"/>
        <Setter Property="Padding" Value="14,0"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FlowDirection" Value="RightToLeft"/>
        <Setter Property="TextAlignment" Value="Right"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="14">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AppSearchTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource AppTextInputStyle}"/>

    <Style x:Key="AppComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Height" Value="54"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FlowDirection" Value="RightToLeft"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,8"/>
    </Style>

    <Style x:Key="AppBadgeBorderStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="Margin" Value="0,0,12,0"/>
        <Setter Property="Background" Value="#EEF3F5"/>
    </Style>

    <Style x:Key="AppCardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="30"/>
    </Style>

    <Style x:Key="AppModernDataGridHeaderStyle" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="#EEF3F5"/>
        <Setter Property="Foreground" Value="#21313C"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>

    <Style x:Key="AppModernDataGridRowStyle" TargetType="DataGridRow">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <Style x:Key="AppModernDataGridStyle" TargetType="DataGrid">
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="CanUserAddRows" Value="False"/>
        <Setter Property="CanUserDeleteRows" Value="False"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="RowHeight" Value="46"/>
        <Setter Property="ColumnHeaderHeight" Value="48"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="RowBackground" Value="#FFFDFB"/>
        <Setter Property="AlternatingRowBackground" Value="#F7FAFB"/>
        <Setter Property="HorizontalGridLinesBrush" Value="#E7EDF0"/>
        <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
        <Setter Property="ColumnHeaderStyle" Value="{StaticResource AppModernDataGridHeaderStyle}"/>
        <Setter Property="RowStyle" Value="{StaticResource AppModernDataGridRowStyle}"/>
    </Style>

    <Style x:Key="AppMenuItemStyle" TargetType="MenuItem">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FlowDirection" Value="RightToLeft"/>
    </Style>

    <Style x:Key="DashboardNavButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource AppSidebarTextBrush}"/>
        <Setter Property="FlowDirection" Value="RightToLeft"/>
        <Setter Property="HorizontalContentAlignment" Value="Right"/>
        <Setter Property="Padding" Value="18,12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontSize" Value="17"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="14" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#224B5A64"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#33596F7A"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
