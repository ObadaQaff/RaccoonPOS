<Window x:Class="RaccoonWarehouse.Vouchers.CreateVoucher"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        mc:Ignorable="d"
        Title="إضافة سند"
        Height="800"
        Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <!-- ============== RESOURCES ============== -->
    <Window.Resources>

        <!-- Primary button (blue) -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2D8DCF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                      CornerRadius="8"
                      Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2479B6"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1E6A9E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary button (light gray-blue) -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button"
     BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#E3EAF0"/>
            <Setter Property="Foreground" Value="#2D8DCF"/>
        </Style>

        <!-- TextBox modern style -->
        <Style x:Key="InputBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CBD5DF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}"
                      CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#2D8DCF"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="6" Color="#A8D2FF" ShadowDepth="0"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern ComboBox -->
        <Style x:Key="ComboBoxStyleModern" TargetType="ComboBox">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="IsEditable" Value="True"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CBD5DF"/>
            <Setter Property="BorderThickness" Value="1"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">

                        <Grid>

                            <!-- Border -->
                            <Border x:Name="Border"
                         Background="{TemplateBinding Background}"
                         BorderBrush="{TemplateBinding BorderBrush}"
                         BorderThickness="{TemplateBinding BorderThickness}"
                         CornerRadius="8"/>

                            <!-- Editable Textbox -->
                            <TextBox x:Name="PART_EditableTextBox"
                          Background="Transparent"
                          BorderThickness="0"
                          Padding="8,0,30,0"
                          VerticalContentAlignment="Center"
                          HorizontalContentAlignment="Right"
                          Visibility="Visible"/>

                            <!-- ToggleButton (Drop arrow) -->
                            <ToggleButton x:Name="DropDownToggle"
                               Grid.Column="1"
                               Focusable="False"
                               Background="Transparent"
                               BorderBrush="Transparent"
                               BorderThickness="0"
                               Width="28"
                               HorizontalAlignment="Left"
                               Content="▼"
                               FontSize="12"
                               Foreground="#777"
                               IsChecked="{Binding IsDropDownOpen,
                                   Mode=TwoWay,
                                   RelativeSource={RelativeSource TemplatedParent}}"/>

                            <!-- Popup -->
                            <Popup x:Name="PART_Popup"
                        Placement="Bottom"
                        IsOpen="{TemplateBinding IsDropDownOpen}"
                        AllowsTransparency="True"
                        Focusable="False"
                        PopupAnimation="Slide">

                                <Border Background="White"
                             BorderBrush="#D0D0D0"
                             BorderThickness="1"
                             CornerRadius="6"
                             Margin="0,2,0,0">

                                    <ScrollViewer Margin="2"
                                       SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                         KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>

                                </Border>
                            </Popup>

                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#2D8DCF"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#2D8DCF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>

        </Style>


        <!-- Modern DataGrid -->
        <Style x:Key="MinimalDataGrid" TargetType="DataGrid">
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="ColumnHeaderHeight" Value="44"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="BorderBrush" Value="#CBD5DF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F2F6FA"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E0E6EB"/>
        </Style>

        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

    </Window.Resources>



    <!-- ============== LAYOUT ============== -->
    <Grid Background="#EEEEEE">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#3396D3" Grid.Row="0">
            <TextBlock Text="سند قبض" 
                       Foreground="White"
                       FontSize="28"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- CONTENT -->
        <ScrollViewer
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled" Margin="0,10,0,50" Grid.RowSpan="2" Grid.Row="1">
            <StackPanel VerticalAlignment="Top"
                        HorizontalAlignment="Center"
                        Width="850"
                        Margin="0,20,0,20"
                        FlowDirection="RightToLeft">




                <!-- Fields Grid -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170"/>
                        <!-- رقم السند -->
                        <ColumnDefinition Width="200"/>
                        <!-- التاريخ -->
                        <ColumnDefinition Width="200"/>
                        <!-- المبلغ -->
                        <ColumnDefinition Width="*"/>
                        <!-- الحساب / الجهة -->
                    </Grid.ColumnDefinitions>

                    <!-- رقم السند -->
                    <StackPanel Margin="6" Grid.Column="0">
                        <TextBlock Text="رقم السند" FontSize="14" FontWeight="SemiBold" Width="154"/>
                        <TextBox x:Name="ReceiptNumber" Style="{StaticResource InputBoxStyle}" Width="150"/>
                    </StackPanel>

                    <!-- التاريخ -->
                    <StackPanel Margin="6" Grid.Column="1">
                        <TextBlock Text="التاريخ" FontSize="14" FontWeight="SemiBold" Width="166"/>
                        <DatePicker x:Name="ReceiptDate" Height="32" FontSize="13" Width="160"/>
                    </StackPanel>

                    <!-- المبلغ -->
                    <StackPanel Margin="6" Grid.Column="2">
                        <TextBlock Text="المبلغ" FontSize="14" FontWeight="SemiBold" Width="163"/>
                        <TextBox x:Name="Amount" Style="{StaticResource InputBoxStyle}" Width="160"/>
                    </StackPanel>

                    <!-- الحساب / الجهة -->
                    <StackPanel Margin="6" Grid.Column="3">
                        <TextBlock Text="الحساب / الجهة" FontSize="14" FontWeight="SemiBold" Width="232"/>
                        <ComboBox x:Name="AccountComboBox"
                  Style="{StaticResource ComboBoxStyleModern}"
                  Width="230"
                  DisplayMemberPath="Name"
                  SelectedValuePath="Id"/>
                    </StackPanel>
                </Grid>

                <StackPanel Margin="6" HorizontalAlignment="Left">
                    <TextBlock Text="طريقة الدفع" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,3" Width="192"/>
                    <ComboBox x:Name="PaymentTypeCombo"
                          Style="{StaticResource ComboBoxStyleModern}"
                       
                          SelectionChanged="PaymentTypeCombo_SelectionChanged">
                        <ComboBoxItem Tag="1">نقدي</ComboBoxItem>
                        <ComboBoxItem Tag="3">شبكة</ComboBoxItem>
                        <ComboBoxItem Tag="2">ذمم</ComboBoxItem>
                        <ComboBoxItem Tag="4">شيك</ComboBoxItem>
                        <ComboBoxItem Tag="5">محفظة</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
                <!-- إدخال بيانات الشيك -->
                <Grid x:Name="CheckFieldsPanel"
                    Visibility="Collapsed"
                    Margin="6">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- رقم الشيك -->
                    <StackPanel Grid.Column="0" Margin="6">
                        <TextBlock Text="رقم الشيك" FontSize="14" FontWeight="SemiBold"/>
                        <TextBox x:Name="CheckNumberBox"
                         Style="{StaticResource InputBoxStyle}"
                         Width="140"/>
                    </StackPanel>

                    <!-- اسم البنك -->
                    <StackPanel Grid.Column="1" Margin="6">
                        <TextBlock Text="اسم البنك" FontSize="14" FontWeight="SemiBold"/>
                        <TextBox x:Name="BankNameBox"
                 Style="{StaticResource InputBoxStyle}"
                 Width="180"/>
                    </StackPanel>

                    <!-- تاريخ الاستحقاق -->
                    <StackPanel Grid.Column="2" Margin="6">
                        <TextBlock Text="تاريخ الاستحقاق" FontSize="14" FontWeight="SemiBold"/>
                        <DatePicker x:Name="CheckDueDatePicker"
                    Height="32"
                    FontSize="13"
                    Width="140"/>
                    </StackPanel>

                    <!-- مبلغ الشيك -->
                    <StackPanel Grid.Column="3" Margin="6">
                        <TextBlock Text="مبلغ الشيك" FontSize="14" FontWeight="SemiBold"/>
                        <TextBox x:Name="CheckAmountBox"
                 Style="{StaticResource InputBoxStyle}"
                 Width="140"/>
                    </StackPanel>

                    <!-- ملاحظات -->
                    <StackPanel Grid.Column="4" Margin="6">
                        <TextBlock Text="ملاحظات" FontSize="14" FontWeight="SemiBold"/>
                        <TextBox x:Name="CheckNotesBox"
                 Style="{StaticResource InputBoxStyle}"
                 Width="200"/>
                    </StackPanel>

                </Grid>


                <!-- معلومات الشيك -->
                <DataGrid x:Name="ChecksGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      Margin="6"
                      HeadersVisibility="Column"
                      RowHeaderWidth="0"
                      Visibility="Collapsed">

                    <DataGrid.Columns>

                        <DataGridTextColumn  Header="رقم الشيك" Binding="{Binding CheckNumber}" Width="150"/>
                        <DataGridTextColumn  Header="البنك" Binding="{Binding BankName}" Width="150"/>
                        <DataGridTextColumn  Header="تاريخ الاستحقاق" Binding="{Binding DueDate}" Width="150"/>
                        <DataGridTextColumn  Header="المبلغ" Binding="{Binding Amount}" Width="100"/>
                        <DataGridTextColumn  Header="ملاحظات" Binding="{Binding Notes}" Width="200"/>

                        <DataGridTemplateColumn Header="حذف" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="🗑"
                                        Foreground="Red"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Click="DeleteCheck_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>


                <Button x:Name="AddCheckButton"
                    Content="إضافة شيك"
                    Width="120"
                    Margin="6"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Visibility="Collapsed"
                    Click="AddCheck_Click"/>
                <!-- الوصف -->
                <StackPanel Margin="10,10,10,0">
                    <TextBlock Text="الوصف" FontSize="16" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,5" Width="804"/>
                    <TextBox x:Name="ReceiptDescription"
                         Style="{StaticResource InputBoxStyle}"
                         Height="70"
                         Width="800"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"/>
                </StackPanel>

                <!-- ACTION BUTTONS -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,30,0,0">
                    <Button x:Name="BackBtn"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="140"
                            Click="BackBtn_Click"
                            Margin="0,0,15,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <fa:ImageAwesome Icon="ArrowLeft" Width="18" Height="18"
                                             Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="رجوع" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="SaveReceiptBtn"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="140"
                            Margin="0,0,15,0"
                            Click="SaveReceiptBtn_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <fa:ImageAwesome Icon="Save" Width="18" Height="18"
                                             Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="حفظ" Margin="8,0,0,0"/>
                        </StackPanel>

                    </Button>
                    <Button x:Name="SearchVoucherBtn"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="140"
                        Margin="0,0,15,0"
                        Click="SearchVoucherBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="Search" Width="18" Height="18"
                                 Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="استعلام" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>


                    <Button x:Name="PrintBtn"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="180"
                        Margin="0,0,15,0"
                        Visibility="Collapsed" 
                        Click="PrintBtn_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <fa:ImageAwesome Icon="Print" Width="18" Height="18"
                         Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"/>
                            <TextBlock Text="طباعة" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="NewVoucherBtn"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="140"
                        Click="NewVoucherBtn_Click"
                        Margin="0,0,15,0"
                        Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <fa:ImageAwesome Icon="Plus" Width="18" Height="18"
                         Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="سند جديد" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- FOOTER -->
        <Border Background="#E8F0F7" Grid.Row="2">
            <TextBlock Text="© 2025 Raccoon Warehouse"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="#3396D3"
                       FontSize="14"
                       FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>
