<Window x:Class="RaccoonWarehouse.Vouchers.SearchVoucherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="بحث عن سند قبض"
        Height="650"
        Width="1000"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FlowDirection="RightToLeft"
        Background="#EEEEEE">

    <Window.Resources>

        <!-- Input TextBox Style -->
        <Style x:Key="InputBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#EBCB90"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="6"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}">
                            <ScrollViewer Margin="2" x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#3396D3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern Button -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#3396D3"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="10,5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBCB90"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <!-- Main Layout -->
    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <Border Background="#3396D3" Padding="12" CornerRadius="8">
            <TextBlock Text="🔍 بحث عن سند قبض/دفع"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Filters Section -->
        <StackPanel Grid.Row="1" Margin="0,20,0,15">

            <UniformGrid Columns="4" Rows="2" Margin="0,0,0,10" HorizontalAlignment="Center">

                <StackPanel Margin="10">
                    <TextBlock Text="رقم السند" FontWeight="Bold"/>
                    <TextBox x:Name="DocNumberTxt" Width="200" Style="{StaticResource InputBoxStyle}"/>
                </StackPanel>

                <StackPanel Margin="10">
                    <TextBlock Text="اسم الحساب / الجهة" FontWeight="Bold"/>
                    <TextBox x:Name="CustomerTxt" Width="200" Style="{StaticResource InputBoxStyle}"/>
                </StackPanel>

                <StackPanel Margin="10">
                    <TextBlock Text="من تاريخ" FontWeight="Bold"/>
                    <DatePicker x:Name="DateFrom" Width="200"/>
                </StackPanel>

                <StackPanel Margin="10">
                    <TextBlock Text="إلى تاريخ" FontWeight="Bold"/>
                    <DatePicker x:Name="DateTo" Width="200"/>
                </StackPanel>

            </UniformGrid>

            <Button Content="بحث"
                    Width="180"
                    Style="{StaticResource PrimaryButtonStyle}"
                    HorizontalAlignment="Center"
                    Click="SearchBtn_Click"/>

            <!-- Results -->
            <Border Margin="0,20,0,0"
                    Background="White"
                    CornerRadius="8"
                    BorderBrush="#EBCB90"
                    BorderThickness="1"
                    Padding="10"
                    Height="320">   

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

                    <DataGrid x:Name="ResultsGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  RowHeaderWidth="0"
                  MouseDoubleClick="ResultsGrid_MouseDoubleClick"
                  Background="White"
                  BorderThickness="0"
                  Margin="0">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="رقم السند" Binding="{Binding Id}" Width="120"/>
                            <DataGridTextColumn Header="التاريخ" Binding="{Binding CreatedDate, StringFormat=yyyy-MM-dd}" Width="130"/>
                            <DataGridTextColumn Header="العميل" Binding="{Binding User.Name}" Width="180"/>
                            <DataGridTextColumn Header="طريقة الدفع" Binding="{Binding PaymentType}" Width="120"/>
                            <DataGridTextColumn Header="المبلغ" Binding="{Binding Amount}" Width="100"/>
                            <DataGridTextColumn Header="عدد الشيكات" Binding="{Binding Checks.Count}" Width="100"/>
                        </DataGrid.Columns>

                    </DataGrid>

                </ScrollViewer>

            </Border>




        </StackPanel>

        <!-- Select Button -->
        <Button Content="اختيار السند"
                Grid.Row="2"
                Width="200"
                Style="{StaticResource PrimaryButtonStyle}"
                HorizontalAlignment="Center"
                Margin="0,10,0,0"
                Click="SelectBtn_Click"/>

    </Grid>
</Window>
