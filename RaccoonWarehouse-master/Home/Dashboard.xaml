<Window x:Class="RaccoonWarehouse.Dashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        mc:Ignorable="d"
        Title="نظام المستودع"
        Height="800"
        Width="1400"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{StaticResource AppPageBackgroundBrush}">

    <Grid Background="{StaticResource AppPageBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="290"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="18"
                Background="{StaticResource AppSidebarBrush}"
                CornerRadius="28"
                Padding="18">
            <DockPanel LastChildFill="True" FlowDirection="RightToLeft">
                <Border DockPanel.Dock="Top"
                        Padding="18"
                        Margin="0,0,0,18"
                        Background="#16FFFFFF"
                        CornerRadius="22">
                    <StackPanel>
                        <TextBlock Text="مدير المستودع"
                                   Foreground="White"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Button Style="{StaticResource DashboardNavButtonStyle}" Margin="0,0,0,8" Click="POSBtn_Click">
                            <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                                <fa:ImageAwesome Icon="ShoppingCart" Width="22" Height="22" Foreground="{StaticResource AppAccentBrush}" Margin="0,0,12,0"/>
                                <TextBlock Text="نقطة البيع" Foreground="{StaticResource AppSidebarTextBrush}" FontSize="18" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource DashboardNavButtonStyle}" Margin="0,0,0,8" Click="Button_Click_3">
                            <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                                <fa:ImageAwesome Icon="FolderOpen" Width="22" Height="22" Foreground="#F0A34A" Margin="0,0,12,0"/>
                                <TextBlock Text="التصنيف والفئات" Foreground="{StaticResource AppSidebarTextBrush}" FontSize="18"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource DashboardNavButtonStyle}" Margin="0,0,0,8" Click="StocksBtn_Click">
                            <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                                <fa:ImageAwesome Icon="Dropbox" Width="22" Height="22" Foreground="#E7D7A5" Margin="0,0,12,0"/>
                                <TextBlock Text="الأصناف" Foreground="{StaticResource AppSidebarTextBrush}" FontSize="18"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource DashboardNavButtonStyle}" Margin="0,0,0,8" Click="Button_Click_6">
                            <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                                <fa:ImageAwesome Icon="Building" Width="22" Height="22" Foreground="#D2B7FF" Margin="0,0,12,0"/>
                                <TextBlock Text="المستودعات" Foreground="{StaticResource AppSidebarTextBrush}" FontSize="18"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource DashboardNavButtonStyle}" Margin="0,0,0,8" Click="Receipt_Click">
                            <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                                <fa:ImageAwesome Icon="File" Width="22" Height="22" Foreground="#CED8DC" Margin="0,0,12,0"/>
                                <TextBlock Text="الفواتير والسندات" Foreground="{StaticResource AppSidebarTextBrush}" FontSize="18"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource DashboardNavButtonStyle}" Margin="0,0,0,8" Click="Button_Click_2">
                            <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                                <fa:ImageAwesome Icon="Tags" Width="22" Height="22" Foreground="#FF8D7A" Margin="0,0,12,0"/>
                                <TextBlock Text="العلامات التجارية" Foreground="{StaticResource AppSidebarTextBrush}" FontSize="18"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource DashboardNavButtonStyle}" Margin="0,0,0,8" Click="Reports_Click">
                            <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                                <fa:ImageAwesome Icon="BarChart" Width="22" Height="22" Foreground="#CFE1E8" Margin="0,0,12,0"/>
                                <TextBlock Text="التقارير" Foreground="{StaticResource AppSidebarTextBrush}" FontSize="18"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource DashboardNavButtonStyle}" Margin="0,0,0,8" Click="Customers_Click">
                            <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                                <fa:ImageAwesome Icon="Users" Width="22" Height="22" Foreground="#F0A34A" Margin="0,0,12,0"/>
                                <TextBlock Text="المستخدمين" Foreground="{StaticResource AppSidebarTextBrush}" FontSize="18"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource DashboardNavButtonStyle}" Click="Button_Click_5">
                            <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                                <fa:ImageAwesome Icon="Cog" Width="22" Height="22" Foreground="#CED8DC" Margin="0,0,12,0"/>
                                <TextBlock Text="إعدادات المستودع" Foreground="{StaticResource AppSidebarTextBrush}" FontSize="18"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource DashboardNavButtonStyle}" Margin="0,16,0,0" Click="LogoutBtn_Click">
                            <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                                <fa:ImageAwesome Icon="SignOut" Width="22" Height="22" Foreground="#FF8D7A" Margin="0,0,12,0"/>
                                <TextBlock Text="تسجيل خروج" Foreground="{StaticResource AppSidebarTextBrush}" FontSize="18"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="0,18,18,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="148"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource AppDashboardHeroBrush}"
                    CornerRadius="32"
                    Padding="28"
                    Margin="0,0,0,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="لوحة التحكم"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="#19FFFFFF"
                            Padding="18,12"
                            CornerRadius="20"
                            VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="المساحة النشطة"
                                       FontSize="12"
                                       Foreground="#D6E7E2"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="جاهزة"
                                       Margin="0,4,0,0"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Style="{StaticResource AppCardBorderStyle}"
                    Padding="20">
                <ContentControl x:Name="MainContent"/>
            </Border>
        </Grid>
    </Grid>
</Window>
