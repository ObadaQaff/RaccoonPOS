<Window x:Class="RaccoonWarehouse.POS.ResumeHeldInvoiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="الفواتير المعلقة"
        Height="450"
        Width="800"
        WindowStartupLocation="CenterOwner"
        Background="#F2F6FA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#2D8DCF" Grid.Row="0">
            <TextBlock Text="الفواتير المعلقة"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- CONTENT -->
        <Border Grid.Row="1"
                Margin="20"
                CornerRadius="12"
                Background="White"
                Padding="10"
                BorderBrush="#D0D7DD"
                BorderThickness="1">

            <DataGrid x:Name="HeldInvoicesGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      FlowDirection="RightToLeft"
                      Style="{StaticResource MinimalDataGrid}"
                      MouseDoubleClick="Grid_DoubleClick">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="رقم الفاتورة"
                                        Binding="{Binding InvoiceNumber}"
                                        Width="150"/>

                    <DataGridTextColumn Header="العميل"
                                        Binding="{Binding User.Name}"
                                        Width="*"/>

                    <DataGridTextColumn Header="الإجمالي"
                                        Binding="{Binding TotalAmount}"
                                        Width="150"/>

                    <DataGridTextColumn Header="الوقت"
                                        Binding="{Binding OpenedAt}"
                                        Width="180"/>
                </DataGrid.Columns>

            </DataGrid>
        </Border>

        <!-- FOOTER -->
        <Border Background="#E3EAF0" Grid.Row="2">
            <TextBlock Text="انقر مرتين لاستئناف الفاتورة"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="#2D8DCF"
                       FontSize="16"
                       FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>
