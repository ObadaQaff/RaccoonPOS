<Window x:Class="RaccoonWarehouse.POS.ReturnInvoiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="مرتجع فاتورة"
        Width="300"
        Height="200"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F6FA"
        WindowStyle="ToolWindow">

    <Grid Margin="8">
        <Border Background="White"
                CornerRadius="10"
                Padding="10"
                BorderBrush="#E0E0E0"
                BorderThickness="1">

            <Grid FlowDirection="RightToLeft">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 🔵 Header -->
                <TextBlock Text="مرتجع فاتورة"
                           FontSize="14"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>

                <!-- 📄 Invoice Number -->
                <StackPanel Grid.Row="1" Margin="0,0,0,10">
                    <TextBlock Text="رقم الفاتورة الأصلية"
                               FontSize="11"
                               FontWeight="SemiBold"/>
                    <TextBox x:Name="InvoiceNumberTextBox"
                             Height="30"
                             FontSize="14"/>
                </StackPanel>

                <!-- 🟢 Buttons -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center">

                    <Button Content="متابعة"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="90"
                            Height="30"
                            Margin="4"
                            Click="Confirm_Click"/>

                    <Button Content="إلغاء"
                            Style="{StaticResource CancelButtonStyle}"
                            Width="90"
                            Height="30"
                            Margin="4"
                            Click="Cancel_Click"/>
                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</Window>
