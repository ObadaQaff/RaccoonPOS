<Window x:Class="RaccoonWarehouse.POS.DailySalesReport"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="التقرير اليومي"
        Height="650"
        Width="1000"
        WindowStartupLocation="CenterOwner"
        Background="#F2F6FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <TextBlock Text="📊 التقرير اليومي للمبيعات"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="#2D8DCF"
                   HorizontalAlignment="Center"/>

        <!-- FILTER -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="12"
                Margin="0,15"
                BorderBrush="#D0D7DD"
                BorderThickness="1">

            <StackPanel Orientation="Horizontal"
                        FlowDirection="RightToLeft"
                        HorizontalAlignment="Center">

                <TextBlock Text="التاريخ:"
                           FontSize="18"
                           Margin="10,0"/>

                <DatePicker x:Name="ReportDatePicker"
                            SelectedDate="{Binding ReportDate}"
                            FontSize="16"
                            Width="200" Height="47"/>

                <Button Style="{StaticResource PrimaryButtonStyle}"
                        Content="تحميل"
                        Width="140"
                        Margin="20,0"
                        Click="LoadReportBtn_Click"/>
            </StackPanel>
        </Border>

        <!-- REPORT GRID -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="12"
                Padding="10"
                BorderBrush="#D0D7DD"
                BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- SUMMARY -->
                <StackPanel Orientation="Horizontal"
                            FlowDirection="RightToLeft"
                            HorizontalAlignment="Center"
                            Margin="0,10">

                    <TextBlock Text="{Binding TotalInvoices, StringFormat=عدد الفواتير: {0}}"
                               FontSize="18"
                               Margin="20,0"/>

                    <TextBlock Text="{Binding TotalSales, StringFormat=إجمالي المبيعات: {0:N2}}"
                               FontSize="18"
                               Margin="20,0"/>

                    <TextBlock Text="{Binding TotalDiscount, StringFormat=الخصم: {0:N2}}"
                               FontSize="18"
                               Margin="20,0"/>

                    <TextBlock Text="{Binding NetSales, StringFormat=الصافي: {0:N2}}"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#27AE60"
                               Margin="20,0"/>
                </StackPanel>

                <!-- DETAILS -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Invoices}"
                          Style="{StaticResource MinimalDataGrid}"
                          AutoGenerateColumns="False"
                          FlowDirection="RightToLeft">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="رقم الفاتورة"
                                            Binding="{Binding InvoiceNumber}"
                                            Width="200"/>

                        <DataGridTextColumn Header="التاريخ"
                                            Binding="{Binding ClosedAt}"
                                            Width="200"/>
                        
                        <DataGridTextColumn Header="العميل"
                                            Binding="{Binding User.Name}"
                                            Width="200"/>
                        
                        <DataGridTextColumn Header="نوع الفاتورة"
                                            Binding="{Binding InvoiceType}"
                                            Width="130"/>

                        <DataGridTextColumn Header="الإجمالي"
                                            Binding="{Binding TotalAmount}"
                                            Width="150"/>

                        <DataGridTextColumn Header="الخصم"
                                            Binding="{Binding DiscountAmount}"
                                            Width="150"/>

                        <DataGridTextColumn Header="الصافي"
                                            Binding="{Binding NetAmount}"
                                            Width="120"/>
                    </DataGrid.Columns>

                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Window>
