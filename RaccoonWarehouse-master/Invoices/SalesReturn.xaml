<Window x:Class="RaccoonWarehouse.Invoices.SalesReturn"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        Title="مردودات المبيعات"
        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <!-- Primary button style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3396D3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                              CornerRadius="8"
                              Padding="15,8"
                              BorderBrush="{TemplateBinding BorderBrush}"
                              BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBCB90"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FFF0CE"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary button style -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#FFF0CE"/>
            <Setter Property="Foreground" Value="#3396D3"/>
        </Style>
    </Window.Resources>

    <Grid Background="#EEEEEE">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#3396D3" Grid.Row="0">
            <TextBlock Text="مردودات المبيعات"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Width="900" HorizontalAlignment="Center" Margin="0,20,0,20">

                <!-- رقم الفاتورة الأصلية -->
                <TextBlock Text="رقم الفاتورة الأصلية" FlowDirection="RightToLeft" FontSize="18"/>
                <TextBox Height="44" FontSize="18" Margin="0,0,0,20"/>

                <!-- التاريخ -->
                <TextBlock Text="التاريخ" FlowDirection="RightToLeft" FontSize="18"/>
                <DatePicker Height="44" FontSize="18" Margin="0,0,0,20"/>

                <!-- اسم الزبون -->
                <TextBlock Text="اسم الزبون" FlowDirection="RightToLeft" FontSize="18"/>
                <TextBox Height="44" FontSize="18" Margin="0,0,0,20"/>

                <!-- سبب المردود -->
                <TextBlock Text="سبب المردود" FlowDirection="RightToLeft" FontSize="18"/>
                <TextBox Height="80" FontSize="18" Margin="0,0,0,20" TextWrapping="Wrap" AcceptsReturn="True"/>

                <!-- المبلغ -->
                <TextBlock Text="المبلغ" FlowDirection="RightToLeft" FontSize="18"/>
                <TextBox Height="44" FontSize="18" Margin="0,0,0,20"/>

                <!-- طريقة الاسترداد -->
                <TextBlock Text="طريقة الاسترداد" FlowDirection="RightToLeft" FontSize="18"/>
                <ComboBox Height="44" FontSize="18" Margin="0,0,0,20">
                    <ComboBoxItem Content="نقدي"/>
                    <ComboBoxItem Content="إضافة رصيد"/>
                    <ComboBoxItem Content="تحويل بنكي"/>
                </ComboBox>

                <!-- ملاحظات -->
                <TextBlock Text="ملاحظات" FlowDirection="RightToLeft" FontSize="18"/>
                <TextBox Height="80" FontSize="18" Margin="0,0,0,20" TextWrapping="Wrap" AcceptsReturn="True"/>

                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,20,0,0">
                    <Button x:Name="BackBtn"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="200"
                            Click="BackBtn_Click"
                            Margin="0,0,20,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <fa:ImageAwesome Icon="ArrowLeft" Width="18" Height="18"
                                             Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text=" رجوع" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="SaveReturnBtn"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="200"
                            Click="SaveReturnBtn_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <fa:ImageAwesome Icon="Undo" Width="18" Height="18"
                                             Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text=" حفظ" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- FOOTER -->
        <Border Background="#FFF0CE" Grid.Row="2">
            <TextBlock Text="© 2025 Raccoon Warehouse"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="#3396D3"
                       FontSize="14"
                       FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>
