<Window x:Class="RaccoonWarehouse.Invoices.ProductSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="بحث عن مادة"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#F2F6FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOP SEARCH BAR -->
        <Border Background="White"
                CornerRadius="12"
                Padding="12"
                BorderBrush="#D0D7DD"
                BorderThickness="1">
            <Grid FlowDirection="RightToLeft">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search box -->
                <TextBox x:Name="SearchTextBox"
                         Height="40"
                         FontSize="16"
                         Padding="0"
                         BorderBrush="#AFC2D3"
                         BorderThickness="2"                         
                         Background="White"
                         HorizontalContentAlignment="Right"
                         VerticalContentAlignment="Center"
                         TextChanged="SearchTextBox_TextChanged"
                         Grid.Column="0"/>

                <!-- Clear -->
                <Button Style="{StaticResource SecondaryButtonStyle}"
                        Content="مسح"
                        Width="120"
                        Margin="10,0,0,0"
                        Grid.Column="1"
                        Click="ClearBtn_Click"/>

                <!-- Close -->
                <Button Style="{StaticResource PrimaryButtonStyle}"
                        Content="إغلاق"
                        Width="120"
                        Margin="10,0,0,0"
                        Grid.Column="2"
                        Click="CloseBtn_Click"/>
            </Grid>
        </Border>

        <!-- RESULTS -->
        <Border Grid.Row="1"
                Margin="0,15,0,10"
                Background="White"
                CornerRadius="12"
                Padding="10"
                BorderBrush="#D0D7DD"
                BorderThickness="1">

            <DataGrid x:Name="ProductsGrid"
                      AutoGenerateColumns="False"
                      Style="{StaticResource MinimalDataGrid}"
                      IsReadOnly="True"
                      FlowDirection="RightToLeft"
                      MouseDoubleClick="ProductsGrid_MouseDoubleClick">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="الباركود / الكود"
                                        Binding="{Binding ITEMCODE}"
                                        Width="200"/>

                    <DataGridTextColumn Header="اسم الصنف"
                                        Binding="{Binding Name}"
                                        Width="*"/>

                    <DataGridTextColumn Header="السعر"
                                        Binding="{Binding ProductUnits[0].SalePrice}"
                                        Width="160"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- FOOTER HINT -->
        <TextBlock Grid.Row="2"
                   Text="💡 اختر الصنف بالنقر مرتين لإضافته إلى الفاتورة"
                   Foreground="#2D8DCF"
                   FontSize="15"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,0"/>
    </Grid>
</Window>
