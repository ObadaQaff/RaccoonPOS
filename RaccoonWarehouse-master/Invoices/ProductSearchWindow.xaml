<Window x:Class="RaccoonWarehouse.Invoices.ProductSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="بحث عن مادة"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#F2F6FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOP SEARCH BAR -->
        <Border Background="White"
                CornerRadius="12"
                Padding="12"
                BorderBrush="#D0D7DD"
                BorderThickness="1">
            <Grid FlowDirection="RightToLeft">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search box -->
                <TextBox x:Name="SearchTextBox"
                         Height="40"
                         FontSize="16"
                         Padding="0"
                         BorderBrush="#AFC2D3"
                         BorderThickness="2"                         
                         Background="White"
                         HorizontalContentAlignment="Right"
                         VerticalContentAlignment="Center"
                         TextChanged="SearchTextBox_TextChanged"
                         Grid.Column="0"/>

                <!-- Clear -->
                <Button Style="{StaticResource SecondaryButtonStyle}"
                        Content="مسح"
                        Width="120"
                        Margin="10,0,0,0"
                        Grid.Column="1"
                        Click="ClearBtn_Click"/>

                <!-- Close -->
                <Button Style="{StaticResource PrimaryButtonStyle}"
                        Content="إغلاق"
                        Width="120"
                        Margin="10,0,0,0"
                        Grid.Column="2"
                        Click="CloseBtn_Click"/>
            </Grid>
        </Border>

        <!-- RESULTS -->
        <Border Grid.Row="1"
                Margin="0,15,0,10"
                Background="White"
                CornerRadius="12"
                Padding="10"
                BorderBrush="#D0D7DD"
                BorderThickness="1">

            <DataGrid x:Name="ProductsGrid"
                      AutoGenerateColumns="False"
                      Style="{StaticResource MinimalDataGrid}"
                      IsReadOnly="True"
                      FlowDirection="RightToLeft">

                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="إضافة" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Width="38"
                                        Height="38"
                                        FontSize="20"
                                        FontWeight="Bold"
                                        Background="#16A34A"
                                        Foreground="White"
                                        BorderBrush="#15803D"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        Click="AddProductBtn_Click"
                                        IsEnabled="{Binding CanAdd}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="ButtonBorder"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="19">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ButtonBorder" Property="Background" Value="#15803D"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="ButtonBorder" Property="Background" Value="#166534"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="ButtonBorder" Property="Background" Value="#E5E7EB"/>
                                                    <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#CBD5E1"/>
                                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                                    <Setter Property="Cursor" Value="Arrow"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <TextBlock Text="+"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="الباركود / الكود"
                                        Binding="{Binding Product.ITEMCODE}"
                                        Width="200"/>

                    <DataGridTextColumn Header="اسم الصنف"
                                        Binding="{Binding Product.Name}"
                                        Width="*"/>

                    <DataGridTextColumn Header="السعر"
                                        Binding="{Binding Product.DefaultSalePrice}"
                                        Width="160"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- FOOTER HINT -->
        <TextBlock Grid.Row="2"
                   Text="اضغط + لإضافة الصنف إلى الفاتورة، وستبقى النافذة مفتوحة حتى تغلقها يدويًا"
                   Foreground="#2D8DCF"
                   FontSize="15"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,0"/>
    </Grid>
</Window>
