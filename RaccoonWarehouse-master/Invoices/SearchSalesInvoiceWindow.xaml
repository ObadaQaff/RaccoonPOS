<Window x:Class="RaccoonWarehouse.Invoices.SearchSalesInvoiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="استعلام عن فاتورة"
        Height="650"
        Width="1000"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        Background="#EEEEEE">

    <Window.Resources>

        <Style x:Key="InputBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#EBCB90"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#3396D3"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>

    </Window.Resources>

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="#3396D3" Padding="12" CornerRadius="8">
            <TextBlock Text="🔍 بحث عن فاتورة"
                       Foreground="White"
                       FontSize="22"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Filters -->
        <StackPanel Grid.Row="1" Margin="0,20,0,10">

            <UniformGrid Columns="4" Margin="0,0,0,10">

                <StackPanel Margin="10">
                    <TextBlock Text="رقم الفاتورة"/>
                    <TextBox x:Name="InvoiceNumberTxt" Style="{StaticResource InputBoxStyle}" Width="200"/>
                </StackPanel>

                <StackPanel Margin="10">
                    <TextBlock Text="اسم الزبون"/>
                    <TextBox x:Name="CustomerTxt" Style="{StaticResource InputBoxStyle}" Width="200"/>
                </StackPanel>

                <StackPanel Margin="10">
                    <TextBlock Text="من تاريخ"/>
                    <DatePicker x:Name="DateFrom" Width="200"/>
                </StackPanel>

                <StackPanel Margin="10">
                    <TextBlock Text="إلى تاريخ"/>
                    <DatePicker x:Name="DateTo" Width="200"/>
                </StackPanel>

            </UniformGrid>

            <Button Content="بحث"
                    Width="180"
                    HorizontalAlignment="Center"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="SearchBtn_Click"/>

            <Border Background="White" Height="320" Margin="0,20,0,0"
                    CornerRadius="8" BorderBrush="#EBCB90" BorderThickness="1" Padding="10">

                <ScrollViewer>
                    <DataGrid x:Name="ResultsGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              MouseDoubleClick="SelectBtn_Click">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="رقم الفاتورة" Binding="{Binding InvoiceNumber}" Width="150"/>
                            <DataGridTextColumn Header="التاريخ" Binding="{Binding CreatedDate,StringFormat=yyyy-MM-dd}" Width="150"/>
                            <DataGridTextColumn Header="الزبون" Binding="{Binding Customer.Name}" Width="200"/>
                            <DataGridTextColumn Header="الإجمالي" Binding="{Binding TotalAmount}" Width="120"/>
                        </DataGrid.Columns>

                    </DataGrid>
                </ScrollViewer>

            </Border>
        </StackPanel>

        <Button Content="اختيار"
                Grid.Row="2"
                Width="200"
                Style="{StaticResource PrimaryButtonStyle}"
                HorizontalAlignment="Center"
                Click="SelectBtn_Click"/>

    </Grid>
</Window>
