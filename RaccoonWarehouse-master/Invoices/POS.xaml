<Window x:Class="RaccoonWarehouse.Invoices.POS"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="نقطة البيع"
        Height="900"
        Width="1600"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F5F6FA"
        PreviewKeyDown="Window_PreviewKeyDown">
                         

    <Window.Resources>
        <!-- POS Button Base Style -->
        <Style x:Key="POSButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="80"/>
            <Setter Property="Width" Value="140"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBCB90"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FFF0CE"/>
                </Trigger>
            </Style.Triggers>
        </Style>




        <Style x:Key="POSButtonBase" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="72"/>
            <Setter Property="Width" Value="135"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                        CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Primary -->
        <Style x:Key="POSPrimaryButton"
       BasedOn="{StaticResource POSButtonBase}"
       TargetType="Button">
            <Setter Property="Background" Value="#2E7D32"/>
        </Style>

        <!-- Danger -->
        <Style x:Key="POSDangerButton"
       BasedOn="{StaticResource POSButtonBase}"
       TargetType="Button">
            <Setter Property="Background" Value="#C62828"/>
        </Style>

        <!-- Neutral -->
        <Style x:Key="POSNeutralButton"
       BasedOn="{StaticResource POSButtonBase}"
       TargetType="Button">
            <Setter Property="Background" Value="#455A64"/>
        </Style>

        <!-- Adjustment -->
        <Style x:Key="POSAdjustmentButton"
       BasedOn="{StaticResource POSButtonBase}"
       TargetType="Button">
            <Setter Property="Background" Value="#F57C00"/>
        </Style>



        <!-- POS Button Color Variants -->
        <Style x:Key="POSButtonBlue" TargetType="Button" BasedOn="{StaticResource POSButtonStyle}">
            <Setter Property="Background" Value="#3498db"/>
        </Style>
        <Style x:Key="POSButtonRed" TargetType="Button" BasedOn="{StaticResource POSButtonStyle}">
            <Setter Property="Background" Value="#e74c3c"/>
        </Style>
        <Style x:Key="POSButtonOrange" TargetType="Button" BasedOn="{StaticResource POSButtonStyle}">
            <Setter Property="Background" Value="#f39c12"/>
        </Style>
        <Style x:Key="POSButtonGreen" TargetType="Button" BasedOn="{StaticResource POSButtonStyle}">
            <Setter Property="Background" Value="#27ae60"/>
        </Style>
        <Style x:Key="POSButtonPurple" TargetType="Button" BasedOn="{StaticResource POSButtonStyle}">
            <Setter Property="Background" Value="#9b59b6"/>
        </Style>
        <Style x:Key="POSButtonDark" TargetType="Button" BasedOn="{StaticResource POSButtonStyle}">
            <Setter Property="Background" Value="#34495e"/>
        </Style>

        <!-- Custom ComboBox Style with DataGrid Dropdown -->
        <Style x:Key="ProductComboBoxWithGridStyle" TargetType="ComboBox">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="IsEditable" Value="True"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CBD5DF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="20"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Border"
                                   Grid.ColumnSpan="2"
                                   Background="{TemplateBinding Background}"
                                   BorderBrush="{TemplateBinding BorderBrush}"
                                   BorderThickness="{TemplateBinding BorderThickness}"
                                   CornerRadius="8"/>
                            <TextBox x:Name="PART_EditableTextBox"
                                    Grid.Column="0"
                                    Margin="3,3,3,3"
                                    Focusable="True"
                                    Background="Transparent"
                                    HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                    IsReadOnly="{Binding IsReadOnly, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <ToggleButton x:Name="ToggleButton"
                                        Grid.Column="1"
                                        Width="20"
                                        Focusable="False"
                                        ClickMode="Press"
                                        IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <Path x:Name="Arrow"
                                     Fill="#666"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Data="M 0 0 L 4 4 L 8 0 Z"/>
                            </ToggleButton>
                            <ContentPresenter Name="ContentSite"
                                            Grid.Column="0"
                                            IsHitTestVisible="False"
                                            Content="{TemplateBinding SelectionBoxItem}"
                                            ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                            ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                            Margin="3,3,3,3"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup"
                                 Placement="Bottom"
                                 IsOpen="{TemplateBinding IsDropDownOpen}"
                                 AllowsTransparency="True"
                                 Focusable="False"
                                 PopupAnimation="Slide"
                                 VerticalOffset="1">
                                <Border x:Name="DropDownBorder"
                                       MaxHeight="450"
                                       MinWidth="{TemplateBinding ActualWidth}"
                                       Width="1200"
                                       Background="White"
                                       BorderBrush="#CBD5DF"
                                       BorderThickness="1"
                                       CornerRadius="8"
                                       Margin="0,5,0,0">
                                    <ScrollViewer Margin="4,6,4,6"
                                                SnapsToDevicePixels="True"
                                                VerticalScrollBarVisibility="Auto"
                                                HorizontalScrollBarVisibility="Auto">
                                        <DataGrid x:Name="ProductGrid"
                                                 ItemsSource="{Binding ItemsSource, RelativeSource={RelativeSource TemplatedParent}}"
                                                 AutoGenerateColumns="False"
                                                 HeadersVisibility="Column"
                                                 SelectionMode="Single"
                                                 SelectionUnit="FullRow"
                                                 IsReadOnly="True"
                                                 GridLinesVisibility="All"
                                                 RowHeight="40"
                                                 FontSize="14"
                                                 FlowDirection="RightToLeft"
                                                 AlternatingRowBackground="#F5F5F5">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="الاسم" Width="220">
                                                    <DataGridTextColumn.Binding>
                                                        <Binding Path="Name">
                                                            <Binding.TargetNullValue>
                                                                <sys:String>---</sys:String>
                                                            </Binding.TargetNullValue>
                                                        </Binding>
                                                    </DataGridTextColumn.Binding>
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Padding" Value="8,5"/>
                                                            <Setter Property="TextWrapping" Value="NoWrap"/>
                                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Header="الباركود" Width="130">
                                                    <DataGridTextColumn.Binding>
                                                        <Binding Path="ITEMCODE">
                                                            <Binding.TargetNullValue>
                                                                <sys:String>---</sys:String>
                                                            </Binding.TargetNullValue>
                                                        </Binding>
                                                    </DataGridTextColumn.Binding>
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Padding" Value="8,5"/>
                                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Header="الفئة" Width="160">
                                                    <DataGridTextColumn.Binding>
                                                        <Binding Path="SubCategory.Name">
                                                            <Binding.TargetNullValue>
                                                                <sys:String>---</sys:String>
                                                            </Binding.TargetNullValue>
                                                        </Binding>
                                                    </DataGridTextColumn.Binding>
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Padding" Value="8,5"/>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Header="العلامة التجارية" Width="160">
                                                    <DataGridTextColumn.Binding>
                                                        <Binding Path="Brand.Name">
                                                            <Binding.TargetNullValue>
                                                                <sys:String>---</sys:String>
                                                            </Binding.TargetNullValue>
                                                        </Binding>
                                                    </DataGridTextColumn.Binding>
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Padding" Value="8,5"/>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Header="الوصف" Width="320">
                                                    <DataGridTextColumn.Binding>
                                                        <Binding Path="Description">
                                                            <Binding.TargetNullValue>
                                                                <sys:String>---</sys:String>
                                                            </Binding.TargetNullValue>
                                                        </Binding>
                                                    </DataGridTextColumn.Binding>
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Padding" Value="8,5"/>
                                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Header="السعر" Width="130">
                                                    <DataGridTextColumn.Binding>
                                                        <Binding Path="ProductUnits[0].SalePrice" StringFormat="{}{0:N2}" FallbackValue="0.00">
                                                            <Binding.TargetNullValue>
                                                                <sys:String>0.00</sys:String>
                                                            </Binding.TargetNullValue>
                                                        </Binding>
                                                    </DataGridTextColumn.Binding>
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                                            <Setter Property="TextAlignment" Value="Left"/>
                                                            <Setter Property="Padding" Value="8,5"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>
                                            </DataGrid.Columns>
                                            <DataGrid.ColumnHeaderStyle>
                                                <Style TargetType="DataGridColumnHeader">
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Background" Value="#E8E8E8"/>
                                                    <Setter Property="Padding" Value="8,5"/>
                                                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                                    <Setter Property="BorderBrush" Value="#D0D0D0"/>
                                                </Style>
                                            </DataGrid.ColumnHeaderStyle>
                                            <DataGrid.RowStyle>
                                                <Style TargetType="DataGridRow">
                                                    <Setter Property="Padding" Value="5,0"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#E3F2FD"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="#BBDEFB"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.RowStyle>
                                        </DataGrid>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#3498db"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#3498db"/>
                            </Trigger>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter Property="IsTabStop" Value="False"/>
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#263238" Grid.Row="0" CornerRadius="0,0,12,12">
            <DockPanel VerticalAlignment="Center">
                <TextBlock Text="نقطة البيع" 
                           Foreground="White"
                           FontSize="28"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           DockPanel.Dock="Top"/>
            </DockPanel>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Top Info (Compact) -->
            <!-- Modern Compact POS Top Bar -->
            <Border Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Height="44"
                Background="#FFFFFF"
                CornerRadius="8"
                Padding="10,0"
                Margin="0,0,0,8"
                BorderBrush="#E6E6E6"
                BorderThickness="1">

                <Grid FlowDirection="RightToLeft"
                    VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="200"/>

                    </Grid.ColumnDefinitions>

                    <!-- Cashier -->
                    <TextBlock Grid.Column="0"
                           Text="الكاشير :"
                           FontSize="12"
                           Foreground="#7F8C8D"
                           VerticalAlignment="Center"/>
                    <TextBlock
                            Name = "CashierName"
                            Text="{Binding CurrentCasherName}"
                            Grid.Column="1"
                            Height="26"
                            FontSize="15"/>

                    <!-- Customer -->
                    <TextBlock Grid.Column="2"
                           Text="العميل"
                           FontSize="12"
                           Foreground="#7F8C8D"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"/>
                    <ComboBox  Name ="CustomerComboBox" Grid.Column="3"
                           Height="26"
                           Margin="6,0"
                           FontSize="12"
                           DisplayMemberPath="Name"/>

                    <!-- Date -->
                    <TextBlock Grid.Column="5"
                       Text="التاريخ"
                       FontSize="12"
                       Foreground="#7F8C8D"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"/>
                    <TextBlock Name ="CurrentDateTextBlock" Grid.Column="6"
                       Text="{Binding CurrentDate}"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Foreground="#2C3E50"
                       Margin="4,0"/>

                    <!-- Transaction 
                    <TextBlock Grid.Column="8"
                           Text="رقم"
                           FontSize="12"
                           Foreground="#7F8C8D"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"/>
                    <TextBlock Grid.Column="9"
                   Text="{Binding TransactionNumber}"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Foreground="#E74C3C"
                   VerticalAlignment="Center"
                   Margin="4,0"/>-->

                    <!-- ✅ Open Session -->
                    <Button x:Name="OpenSessionBtn"
        Grid.Column="8"
        Height="28"
        MinWidth="95"
        Margin="6,0,0,0"
        Background="#2E7D32"
        Foreground="White"
        FontSize="12"
        FontWeight="SemiBold"
        BorderThickness="0"
        Click="OpenSessionBtn_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="PlayCircle" Width="16" Height="16"/>
                            <TextBlock Text="فتح جلسة" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- ✅ Close Session -->
                    <Button x:Name="CloseSessionBtn"
        Grid.Column="9"
        Height="28"
        MinWidth="95"
        Margin="6,0,0,0"
        Background="#C62828"
        Foreground="White"
        FontSize="12"
        FontWeight="SemiBold"
        BorderThickness="0"
        Click="CloseSessionBtn_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="StopCircle" Width="16" Height="16"/>
                            <TextBlock Text="إغلاق جلسة" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <!-- Barcode -->
                    <TextBlock Grid.Column="10"
                        Text="باركود"
                        FontSize="12"
                        Foreground="#7F8C8D"
                        VerticalAlignment="Center"
                        Margin="12,0,4,0"/>

                    <TextBox Grid.Column="11"
                        x:Name="BarcodeTextBox"
                        Height="26"
                        FontSize="13"
                        VerticalContentAlignment="Center"
                        FlowDirection="LeftToRight"
                        ToolTip="Scan or enter barcode"
                        PreviewKeyDown="BarcodeTextBox_PreviewKeyDown" TextChanged="BarcodeTextBox_TextChanged"/>

                </Grid>

            </Border>

            <!-- Invoice Grid -->
            <Border Grid.Row="1"
                    Grid.Column="0"
                    Margin="10"
                    Padding="10"
                    Background="White"
                    CornerRadius="12"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1">
                
        
                <DataGrid x:Name="InvoiceGrid"
                              AutoGenerateColumns="False"
                              FontSize="16"
                              FlowDirection="RightToLeft"
                              Margin="11,-1,-1,11"
                              Background="White"
                              BorderBrush="#E0E0E0"
                              BorderThickness="1"
                              RowHeight="40"
                              HeadersVisibility="Column"
                              SelectionUnit="Cell"
                              SelectionMode="Single"
                              IsReadOnly="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="True"
                              KeyboardNavigation.TabNavigation="Continue"
                              PreviewKeyDown="InvoiceGrid_PreviewKeyDown"
                              PreparingCellForEdit="InvoiceGrid_PreparingCellForEdit"
                          >

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="رمز الصنف"
                        Width="*"
                        Binding="{Binding ProductId ,Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <DataGridTemplateColumn Header="الصنف" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ProductName, TargetNullValue='---'}" 
                                               VerticalAlignment="Center"
                                               Padding="5,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox 
                                        x:Name="ProductComboBox"
                                        DisplayMemberPath="Name"
                                        Style="{StaticResource ProductComboBoxWithGridStyle}"
                                        SelectedItem="{Binding SelectedProduct, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        ItemsSource="{Binding DataContext.ProductSuggestions, RelativeSource={RelativeSource AncestorType=Window}}"
                                        SelectionChanged="ProductCombo_SelectionChanged"
                                        Loaded="ProductCombo_Loaded"
                                        DropDownOpened="ProductCombo_DropDownOpened"
                                        LostFocus="ProductCombo_LostFocus"
                                        />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>






                        <DataGridTextColumn Header="الكمية"
                        Width="*"
                        Binding="{Binding Quantity ,Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <DataGridTextColumn Header="السعر"
                        Width="*"
                        Binding="{Binding UnitPrice ,Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <DataGridTextColumn Header="الإجمالي"
                        Width="*"
                        IsReadOnly="True"
                        Binding="{Binding LineTotal}"/>
                    </DataGrid.Columns>

                </DataGrid>
            </Border>

            <Border Grid.Row="1"
                Grid.Column="1"
                Margin="10,10,10,-23"
                Padding="15"
                Background="White"
                CornerRadius="12"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                Grid.RowSpan="2">

                <Grid FlowDirection="RightToLeft">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Total -->
                        <RowDefinition Height="*"/>
                        <!-- Actions -->
                        <RowDefinition Height="Auto"/>
                        <!-- Payments -->
                    </Grid.RowDefinitions>

                    <!-- 🔴 TOTAL -->
                    <Border Grid.Row="0"
                        Background="#FFF5F5"
                        CornerRadius="10"
                        Padding="15"
                        Margin="0,0,0,15">
                        <TextBlock Name="TotalTextBlock"
                        Text="0.000"
                        FontSize="36"
                        FontWeight="Bold"
                        Foreground="#E74C3C"
                        HorizontalAlignment="Center"/>
                    </Border>

                    <!-- 🔵 ACTION BUTTONS (SCROLLABLE) -->
                    <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

                        <WrapPanel HorizontalAlignment="Center"
                           ItemHeight="90"
                           ItemWidth="150"  
                           Margin="0,0,0,10">

                            <Button Style="{StaticResource POSNeutralButton}"
                                Click="SearchProductBtn_Click">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="Magnify" Width="28" Height="28"/>
                                    <TextBlock Text="بحث عن مادة"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource POSAdjustmentButton}"
                                Click="ExchangeItemBtn_Click">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="SwapHorizontal" Width="28" Height="28"/>
                                    <TextBlock Text="استبدال"/>
                                </StackPanel>
                            </Button>


                            <Button Style="{StaticResource POSDangerButton}"
                                Click="DeleteItemBtn_Click">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="Delete" Width="28" Height="28"/>
                                    <TextBlock Text="حذف مادة"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource POSDangerButton}"
                                Click="ReturnItemBtn_Click">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="Undo" Width="28" Height="28"/>
                                    <TextBlock Text="مرتجع"/>
                                </StackPanel>
                            </Button>


                            <Button Style="{StaticResource POSPrimaryButton}" Name="FinishSaleBtn" Click="FinishSaleBtn_Click">

                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="CheckBold" Width="28" Height="28"/>
                                    <TextBlock Text="إنهاء"/>

                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource POSButtonDark}"
                                Click="NewInvoiceBtn_Click">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="FileDocument" Width="28" Height="28"/>
                                    <TextBlock Text="فاتورة جديدة"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource POSNeutralButton}"
                                Click="PrintBtn_Click">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="Printer" Width="28" Height="28"/>
                                    <TextBlock Text="طباعة"/>
                                </StackPanel>
                            </Button>
                            <!-- 💰 المقبوضات -->
                            <Button Style="{StaticResource POSPrimaryButton}"
                                         Click="OpenReceipt_Click">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="CashPlus" Width="28" Height="28"/>
                                    <TextBlock Text="مقبوضات"/>
                                </StackPanel>
                            </Button>

                            <!-- 💸 المدفوعات -->
                            <Button Style="{StaticResource POSDangerButton}"
                                Click="OpenPayment_Click">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="CashMinus" Width="28" Height="28"/>
                                    <TextBlock Text="مدفوعات"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource POSAdjustmentButton}">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="Sale" Width="28" Height="28"/>
                                    <TextBlock Text="خصم"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource POSAdjustmentButton}" Click="HoldSaleBtn_Click">

                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="PauseCircle" Width="28" Height="28"/>
                                    <TextBlock Text="انتظار"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource POSDangerButton}" Click="CancelInvoiceBtn_Click">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="Cancel" Width="28" Height="28"/>
                                    <TextBlock Text="إلغاء"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource POSNeutralButton}"
                                        Click="DailyReportBtn_Click">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="ChartBar" Width="28" Height="28"/>
                                    <TextBlock Text="تقرير يومي"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource POSNeutralButton}"
                                Click="ResumeHoldBtn_Click">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="PlayCircle"
                                        Width="28"
                                        Height="28"/>       
                                    <TextBlock Text="استئناف"/>
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                    </ScrollViewer>

                    <!-- 🟢 PAYMENT METHODS (ONE LINE) -->
                    <Border Grid.Row="2"
                        Margin="0,10,0,0"
                        Padding="10"
                        Background="#FAFAFA"
                        CornerRadius="10">

                        <!-- Payment Methods -->
                        <ScrollViewer
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Disabled"
                            Margin="0,10,0,0">

                            <StackPanel
                                Orientation="Horizontal"
                                HorizontalAlignment="Center">

                                <Button Style="{StaticResource POSPrimaryButton}"
                                    Width="110"
                                    Height="40"
                                    Margin="5,0"
                                    Click="CashPaymentBtn_Click">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <iconPacks:PackIconMaterial Kind="Cash" Width="22" Height="22"/>
                                        <TextBlock Text="كاش" Margin="5,0,0,0"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource POSNeutralButton}"
                                    Width="110"
                                    Height="40"
                                    Margin="5,0"
                                    Click="VisaPaymentBtn_Click">   
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <iconPacks:PackIconMaterial Kind="CreditCard" Width="22" Height="22"/>
                                        <TextBlock Text="Visa" Margin="5,0,0,0"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource POSNeutralButton}"
                                    Width="110"
                                    Height="40"
                                    Margin="5,0"
                                    Click="MasterCardPaymentBtn_Click"> 
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <iconPacks:PackIconMaterial Kind="CreditCardOutline" Width="22" Height="22"/>
                                        <TextBlock Text="Master" Margin="5,0,0,0"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource POSAdjustmentButton}"
                                    Width="110"
                                    Height="40"
                                    Margin="5,0"
                                    Click="CreditPaymentBtn_Click">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <iconPacks:PackIconMaterial Kind="AccountClock" Width="22" Height="22"/>
                                        <TextBlock Text="آجل" Margin="5,0,0,0"/>
                                    </StackPanel>
                                </Button>

                            </StackPanel>
                        </ScrollViewer>

                    </Border>

                </Grid>
            </Border>


            <!-- Bottom Totals -->
            <Border Grid.Row="2"
                Grid.Column="0"
                Grid.ColumnSpan="1"
                Background="#FAFAFA"
                CornerRadius="10"
                Padding="10"
                Margin="10">
                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" FlowDirection="RightToLeft" Margin="10">
                    <TextBlock Text="العدد: 0" FontSize="20" Margin="10,0"/>
                    <TextBlock Text="الكمية: 0" FontSize="20" Margin="10,0"/>
                    <TextBlock Text="الإجمالي: 0.000" FontSize="20" Margin="10,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- FOOTER -->
        <Border Background="#FFF0CE" Grid.Row="2">
            <TextBlock Text="© 2025 Raccoon Warehouse"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="#3396D3"
                       FontSize="14"
                       FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>
