<Window x:Class="RaccoonWarehouse.Invoices.POS"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="نقطة البيع"
        Width="1600"
        Height="900"
        MinWidth="1180"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{StaticResource AppPageBackgroundBrush}"
        FlowDirection="RightToLeft"
        Loaded="Window_Loaded"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <Style x:Key="POSButtonBase" TargetType="Button" BasedOn="{StaticResource AppFormButtonStyle}">
            <Setter Property="MinHeight" Value="62"/>
            <Setter Property="MinWidth" Value="126"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="POSPrimaryButton" TargetType="Button" BasedOn="{StaticResource POSButtonBase}">
            <Setter Property="Background" Value="{StaticResource AppPrimaryBrush}"/>
        </Style>
        <Style x:Key="POSDangerButton" TargetType="Button" BasedOn="{StaticResource POSButtonBase}">
            <Setter Property="Background" Value="#C93F4D"/>
        </Style>
        <Style x:Key="POSNeutralButton" TargetType="Button" BasedOn="{StaticResource POSButtonBase}">
            <Setter Property="Background" Value="#445A68"/>
        </Style>
        <Style x:Key="POSAdjustmentButton" TargetType="Button" BasedOn="{StaticResource POSButtonBase}">
            <Setter Property="Background" Value="#D98A1F"/>
        </Style>
        <Style x:Key="POSButtonDark" TargetType="Button" BasedOn="{StaticResource POSNeutralButton}">
            <Setter Property="Background" Value="{StaticResource AppPrimaryDarkBrush}"/>
        </Style>
        <Style x:Key="POSInfoLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource AppFieldLabelStyle}">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="POSInfoValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Right"/>
        </Style>
        <Style x:Key="POSSummaryCardStyle" TargetType="Border" BasedOn="{StaticResource AppCardBorderStyle}">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style x:Key="POSMiniActionButtonStyle" TargetType="Button" BasedOn="{StaticResource AppHeroButtonStyle}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="ProductComboBoxWithGridStyle" TargetType="ComboBox">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="IsEditable" Value="True"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="34"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Border" Grid.ColumnSpan="2" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12"/>
                            <TextBox x:Name="PART_EditableTextBox" Grid.Column="0" Margin="8,5,4,5" Padding="0" Focusable="True" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalContentAlignment="Center" IsReadOnly="{Binding IsReadOnly, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <ToggleButton x:Name="ToggleButton" Grid.Column="1" Width="34" Focusable="False" Background="Transparent" BorderThickness="0" ClickMode="Press" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <Path x:Name="Arrow" Fill="#667784" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 4 4 L 8 0 Z"/>
                            </ToggleButton>
                            <ContentPresenter Name="ContentSite" Grid.Column="0" Margin="10,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide" VerticalOffset="2">
                                <Border x:Name="DropDownBorder" MaxHeight="460" MinWidth="{TemplateBinding ActualWidth}" Width="1080" Background="White" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" CornerRadius="14" Margin="0,6,0,0" Padding="6">
                                    <ScrollViewer SnapsToDevicePixels="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                        <DataGrid x:Name="ProductGrid" ItemsSource="{Binding ItemsSource, RelativeSource={RelativeSource TemplatedParent}}" AutoGenerateColumns="False" HeadersVisibility="Column" SelectionMode="Single" SelectionUnit="FullRow" IsReadOnly="True" GridLinesVisibility="Horizontal" RowHeight="40" FontSize="14" FlowDirection="RightToLeft" AlternatingRowBackground="#F7F9FB" Background="White" BorderThickness="0">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="الاسم" Width="220" Binding="{Binding Name, TargetNullValue=---}"/>
                                                <DataGridTextColumn Header="الباركود" Width="130" Binding="{Binding ITEMCODE, TargetNullValue=---}"/>
                                                <DataGridTextColumn Header="الفئة" Width="160" Binding="{Binding SubCategory.Name, TargetNullValue=---}"/>
                                                <DataGridTextColumn Header="العلامة التجارية" Width="160" Binding="{Binding Brand.Name, TargetNullValue=---}"/>
                                                <DataGridTextColumn Header="الوصف" Width="320" Binding="{Binding Description, TargetNullValue=---}"/>
                                                <DataGridTextColumn Header="السعر" Width="130" Binding="{Binding DefaultSalePrice, StringFormat={}{0:N2}, FallbackValue=0.00}"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AppBlueBrush}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AppBlueBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter Property="IsTabStop" Value="False"/>
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="24,18,24,12" Padding="18" CornerRadius="22" Background="{StaticResource AppDashboardHeroBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="نقطة البيع" Foreground="White" FontSize="28" FontWeight="Bold"/>
                </StackPanel>
                <WrapPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left" ItemHeight="38" Margin="18,0,0,0">

                </WrapPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="24,0,24,18" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="10" Margin="0,0,0,10" Style="{StaticResource AppCardBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="138"/>
                            <ColumnDefinition Width="138"/>
                            <ColumnDefinition Width="176"/>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="112"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Margin="0,0,8,0" Style="{StaticResource POSSummaryCardStyle}" Background="#F6FBF7">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource POSInfoLabelStyle}" Text="الكاشير" Margin="0,0,0,4" FontSize="11"/>
                                <TextBlock x:Name="CashierName" Style="{StaticResource POSInfoValueStyle}" Text="{Binding CurrentCasherName}" FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Margin="0,0,8,0" Style="{StaticResource POSSummaryCardStyle}" Background="#F7FAFE">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource POSInfoLabelStyle}" Text="التاريخ" Margin="0,0,0,4" FontSize="11"/>
                                <TextBlock x:Name="CurrentDateTextBlock" Style="{StaticResource POSInfoValueStyle}" Text="{Binding CurrentDate}" FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Margin="0,0,8,0" Style="{StaticResource POSSummaryCardStyle}" Background="#FBFAF6">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource POSInfoLabelStyle}" Text="العميل" Margin="0,0,0,4" FontSize="11"/>
                                <ComboBox x:Name="CustomerComboBox" Height="34" DisplayMemberPath="Name" Style="{StaticResource AppComboBoxStyle}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="3" Margin="0,0,8,0" Style="{StaticResource POSSummaryCardStyle}" Background="White">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource POSInfoLabelStyle}" Text="بحث بالباركود" Margin="0,0,0,4" FontSize="11"/>
                                <TextBox x:Name="BarcodeTextBox" Height="34" FontSize="12" Padding="10,0" VerticalContentAlignment="Center" Background="White" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" FlowDirection="LeftToRight" ToolTip="Scan or enter barcode" PreviewKeyDown="BarcodeTextBox_PreviewKeyDown" TextChanged="BarcodeTextBox_TextChanged"/>
                            </StackPanel>
                        </Border>

                        <WrapPanel Grid.Column="4" ItemHeight="32" Orientation="Vertical" VerticalAlignment="Center">
                            <Button x:Name="OpenSessionBtn" Click="OpenSessionBtn_Click" Style="{StaticResource POSMiniActionButtonStyle}" Background="{StaticResource AppPrimaryBrush}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="PlayCircle" Width="12" Height="12"/>
                                    <TextBlock Text="فتح جلسة" Margin="5,0,0,0"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="CloseSessionBtn" Margin="0,4,0,0" Click="CloseSessionBtn_Click" Style="{StaticResource POSMiniActionButtonStyle}" Background="#C93F4D">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="StopCircle" Width="12" Height="12"/>
                                    <TextBlock Text="إغلاق جلسة" Margin="5,0,0,0"/>
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                    </Grid>
                </Border>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.6*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="1.4*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Padding="18" MinHeight="540" Style="{StaticResource AppCardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel Margin="0,0,0,12">
                                <Border DockPanel.Dock="Right" Style="{StaticResource AppBadgeBorderStyle}" Background="#EEF7EF">
                                    <TextBlock Text="المنتجات داخل الفاتورة" Foreground="{StaticResource AppPrimaryDarkBrush}" FontWeight="SemiBold"/>
                                </Border>
                                <TextBlock Text="تفاصيل الفاتورة" VerticalAlignment="Center" Foreground="{StaticResource AppTextBrush}" FontSize="21" FontWeight="Bold"/>
                            </DockPanel>
                            <DataGrid x:Name="InvoiceGrid" Grid.Row="1" AutoGenerateColumns="False" FontSize="14" FlowDirection="RightToLeft" Style="{StaticResource AppModernDataGridStyle}" Background="White" RowHeight="40" HeadersVisibility="Column" SelectionUnit="Cell" SelectionMode="Single" IsReadOnly="False" CanUserAddRows="False" CanUserDeleteRows="True" KeyboardNavigation.TabNavigation="Continue" PreviewKeyDown="InvoiceGrid_PreviewKeyDown" PreparingCellForEdit="InvoiceGrid_PreparingCellForEdit" CellEditEnding="InvoiceGrid_CellEditEnding">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="رمز الصنف" Width="*" Binding="{Binding ProductId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <DataGridTemplateColumn Header="الصنف" Width="2.2*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ProductName, TargetNullValue='---'}" VerticalAlignment="Center" Padding="8,0"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <ComboBox x:Name="ProductComboBox" DisplayMemberPath="Name" Style="{StaticResource ProductComboBoxWithGridStyle}" SelectedItem="{Binding SelectedProduct, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ItemsSource="{Binding DataContext.ProductSuggestions, RelativeSource={RelativeSource AncestorType=Window}}" SelectionChanged="ProductCombo_SelectionChanged" Loaded="ProductCombo_Loaded" DropDownOpened="ProductCombo_DropDownOpened" LostFocus="ProductCombo_LostFocus"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="الكمية" Width="*" Binding="{Binding Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <DataGridTextColumn Header="السعر" Width="*" Binding="{Binding UnitPrice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <DataGridTextColumn Header="الإجمالي" Width="*" IsReadOnly="True" Binding="{Binding LineTotal}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                    <Border Grid.Column="2" Padding="18" MinHeight="540" Style="{StaticResource AppCardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="الحساب والإجراءات" Foreground="{StaticResource AppTextBrush}" FontSize="21" FontWeight="Bold"/>
                            <Border Grid.Row="1" Margin="0,12,0,14" Padding="14" CornerRadius="18" Background="#FBF7F3" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock x:Name="TotalTextBlock" Text="0.000" FontSize="32" FontWeight="Bold" Foreground="#C93F4D" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Grid Grid.Row="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                    <Grid Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">
                                        <StackPanel>
                                            <TextBlock Text="إجراءات الفاتورة" Margin="0,0,0,10" Foreground="{StaticResource AppMutedTextBrush}" FontSize="13" FontWeight="SemiBold"/>
                                            <WrapPanel ItemHeight="72" ItemWidth="126" HorizontalAlignment="Right">
                                                <Button Style="{StaticResource POSNeutralButton}" Click="SearchProductBtn_Click" ToolTip="اختصار: F2">
                                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                                        <iconPacks:PackIconMaterial Kind="Magnify" Width="22" Height="22"/>
                                                        <TextBlock Text="بحث عن مادة"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource POSAdjustmentButton}" Click="ExchangeItemBtn_Click">
                                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                                        <iconPacks:PackIconMaterial Kind="SwapHorizontal" Width="22" Height="22"/>
                                                        <TextBlock Text="استبدال"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource POSDangerButton}" Click="DeleteItemBtn_Click" ToolTip="اختصار: F3 أو Delete">
                                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                                        <iconPacks:PackIconMaterial Kind="Delete" Width="22" Height="22"/>
                                                        <TextBlock Text="حذف مادة"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource POSDangerButton}" Click="ReturnItemBtn_Click">
                                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                                        <iconPacks:PackIconMaterial Kind="Undo" Width="22" Height="22"/>
                                                        <TextBlock Text="مرتجع"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button x:Name="FinishSaleBtn" Style="{StaticResource POSPrimaryButton}" Click="FinishSaleBtn_Click" ToolTip="اختصار: F4">
                                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                                        <iconPacks:PackIconMaterial Kind="CheckBold" Width="22" Height="22"/>
                                                        <TextBlock Text="إنهاء كاش"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource POSButtonDark}" Click="NewInvoiceBtn_Click" ToolTip="اختصار: F1">
                                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                                        <iconPacks:PackIconMaterial Kind="FileDocument" Width="22" Height="22"/>
                                                        <TextBlock Text="فاتورة جديدة"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource POSNeutralButton}" Click="PrintBtn_Click">
                                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                                        <iconPacks:PackIconMaterial Kind="Printer" Width="22" Height="22"/>
                                                        <TextBlock Text="طباعة"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource POSPrimaryButton}" Click="OpenReceipt_Click">
                                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                                        <iconPacks:PackIconMaterial Kind="CashPlus" Width="22" Height="22"/>
                                                        <TextBlock Text="مقبوضات"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource POSDangerButton}" Click="OpenPayment_Click">
                                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                                        <iconPacks:PackIconMaterial Kind="CashMinus" Width="22" Height="22"/>
                                                        <TextBlock Text="مدفوعات"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource POSAdjustmentButton}">
                                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                                        <iconPacks:PackIconMaterial Kind="Sale" Width="22" Height="22"/>
                                                        <TextBlock Text="خصم"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource POSAdjustmentButton}" Click="HoldSaleBtn_Click" ToolTip="اختصار: F5">
                                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                                        <iconPacks:PackIconMaterial Kind="PauseCircle" Width="22" Height="22"/>
                                                        <TextBlock Text="انتظار"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource POSDangerButton}" Click="CancelInvoiceBtn_Click" ToolTip="اختصار: Esc">
                                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                                        <iconPacks:PackIconMaterial Kind="Cancel" Width="22" Height="22"/>
                                                        <TextBlock Text="إلغاء"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource POSNeutralButton}" Click="DailyReportBtn_Click">
                                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                                        <iconPacks:PackIconMaterial Kind="ChartBar" Width="22" Height="22"/>
                                                        <TextBlock Text="تقرير يومي"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource POSNeutralButton}" Click="ResumeHoldBtn_Click" ToolTip="اختصار: F6">
                                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                                        <iconPacks:PackIconMaterial Kind="PlayCircle" Width="22" Height="22"/>
                                                        <TextBlock Text="استئناف"/>
                                                    </StackPanel>
                                                </Button>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Grid>
                                </ScrollViewer>
                                <Border Grid.Row="1" Margin="0,14,0,0" Padding="14" CornerRadius="18" Background="#F7FAFE" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="طرق الدفع" Margin="0,0,0,10" Foreground="{StaticResource AppMutedTextBrush}" FontSize="13" FontWeight="SemiBold"/>
                                        <WrapPanel ItemHeight="44" ItemWidth="120" HorizontalAlignment="Right">
                                            <Button Style="{StaticResource POSPrimaryButton}" Height="44" MinWidth="120" Click="CashPaymentBtn_Click">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <iconPacks:PackIconMaterial Kind="Cash" Width="18" Height="18"/>
                                                    <TextBlock Text="كاش" Margin="8,0,0,0"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource POSNeutralButton}" Height="44" MinWidth="120" Click="VisaPaymentBtn_Click">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <iconPacks:PackIconMaterial Kind="CreditCard" Width="18" Height="18"/>
                                                    <TextBlock Text="Visa" Margin="8,0,0,0"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource POSNeutralButton}" Height="44" MinWidth="120" Click="MasterCardPaymentBtn_Click">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <iconPacks:PackIconMaterial Kind="CreditCardOutline" Width="18" Height="18"/>
                                                    <TextBlock Text="Master" Margin="8,0,0,0"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource POSAdjustmentButton}" Height="44" MinWidth="120" Click="CreditPaymentBtn_Click">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <iconPacks:PackIconMaterial Kind="AccountClock" Width="18" Height="18"/>
                                                    <TextBlock Text="آجل" Margin="8,0,0,0"/>
                                                </StackPanel>
                                            </Button>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="2" Margin="0,18,0,0" Padding="18" Style="{StaticResource AppCardBorderStyle}">
                    <WrapPanel HorizontalAlignment="Right">
                        <TextBlock Text="العدد: 0" Margin="0,0,18,0" FontSize="18" Foreground="{StaticResource AppTextBrush}"/>
                        <TextBlock Text="الكمية: 0" Margin="0,0,18,0" FontSize="18" Foreground="{StaticResource AppTextBrush}"/>
                        <TextBlock Text="الإجمالي: 0.000" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryDarkBrush}"/>
                    </WrapPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2" Margin="24,0,24,24" Padding="14" CornerRadius="18" Background="#F4EAD7">
            <TextBlock Text="© 2025 Raccoon Warehouse" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource AppBlueBrush}" FontSize="13" FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>
