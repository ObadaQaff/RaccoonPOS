<Window x:Class="RaccoonWarehouse.Invoices.Reports.InvoicesProfitBrowser"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        Title="عرض الفواتير - التكلفة والضريبة والربح"
        Height="850" Width="1500"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F2F6FA"
        FlowDirection="RightToLeft">

    <Window.Resources>

        <!-- Primary button -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2D8DCF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary button -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#E3EAF0"/>
            <Setter Property="Foreground" Value="#2D8DCF"/>
        </Style>

        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CBD5DF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="MinimalDataGrid" TargetType="DataGrid">
            <Setter Property="RowHeight" Value="38"/>
            <Setter Property="ColumnHeaderHeight" Value="42"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="BorderBrush" Value="#D0D7DD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="AlternatingRowBackground" Value="#F7FAFD"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#D0D7DD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="6"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#2D8DCF" Grid.Row="0" Padding="16">
            <TextBlock Text="عرض الفواتير - التكلفة والضريبة والربح"
                       Foreground="White"
                       FontSize="26"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- FILTER BAR -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                BorderBrush="#D0D7DD"
                BorderThickness="1"
                Padding="12"
                Margin="20,14,20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="8,0">
                    <TextBlock Text="من تاريخ" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,6"/>
                    <DatePicker x:Name="FromDatePicker" Height="38" FontSize="14"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="8,0">
                    <TextBlock Text="إلى تاريخ" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,6"/>
                    <DatePicker x:Name="ToDatePicker" Height="38" FontSize="14"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="8,0">
                    <TextBlock Text="الزبون" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,6"/>
                    <ComboBox x:Name="CustomerComboBox"
                              Style="{StaticResource ComboStyle}"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="8,0">
                    <TextBlock Text="نوع الفاتورة" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,6"/>
                    <ComboBox x:Name="InvoiceTypeComboBox" Style="{StaticResource ComboStyle}"/>
                </StackPanel>

                <StackPanel Grid.Column="4"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Bottom"
                            Margin="8,0">
                    <Button Style="{StaticResource PrimaryButtonStyle}" Width="160" Click="LoadBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="Search" Width="16" Height="16"/>
                            <TextBlock Text=" تحميل" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SecondaryButtonStyle}" Width="140" Margin="10,0,0,0" Click="BackBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="ArrowLeft" Width="16" Height="16"/>
                            <TextBlock Text=" رجوع" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="2" Margin="20,0,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="1.35*"/>
            </Grid.ColumnDefinitions>

            <!-- INVOICES GRID (Left) -->
            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="12"
                    BorderBrush="#D0D7DD"
                    BorderThickness="1"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="الفواتير"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <DataGrid x:Name="InvoicesGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              Style="{StaticResource MinimalDataGrid}"
                              SelectionChanged="InvoicesGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="رقم" Binding="{Binding InvoiceNumber}" Width="170"/>
                            <DataGridTextColumn Header="التاريخ" Binding="{Binding Date, StringFormat=yyyy-MM-dd HH:mm}" Width="160"/>
                            <DataGridTextColumn Header="الزبون" Binding="{Binding CustomerName}" Width="220"/>

                            <DataGridTextColumn Header="SubTotal" Binding="{Binding SubTotal}" Width="120"/>
                            <DataGridTextColumn Header="Tax" Binding="{Binding TotalTax}" Width="100"/>
                            <DataGridTextColumn Header="Discount" Binding="{Binding Discount}" Width="110"/>
                            <DataGridTextColumn Header="COGS" Binding="{Binding TotalCOGS}" Width="110"/>

                            <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount}" Width="120"/>
                            <DataGridTextColumn Header="Profit" Binding="{Binding NetProfit}" Width="120"/>

                            <DataGridTextColumn Header="نوع" Binding="{Binding InvoiceType}" Width="110"/>
                            <DataGridTextColumn Header="دفع" Binding="{Binding PaymentMethod}" Width="110"/>
                            <DataGridTextColumn Header="حالة" Binding="{Binding Status}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- DETAILS (Right) -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Selected invoice summary cards -->
                <UniformGrid Grid.Row="0" Columns="6" Margin="0,0,0,10">
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="SubTotal" Foreground="#666"/>
                            <TextBlock x:Name="SelSubTotalText" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="Tax" Foreground="#666"/>
                            <TextBlock x:Name="SelTaxText" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="Discount" Foreground="#666"/>
                            <TextBlock x:Name="SelDiscountText" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="COGS" Foreground="#666"/>
                            <TextBlock x:Name="SelCogsText" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="Gross Profit" Foreground="#666"/>
                            <TextBlock x:Name="SelGrossProfitText" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="Net Profit" Foreground="#666"/>
                            <TextBlock x:Name="SelNetProfitText" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Title -->
                <TextBlock Grid.Row="1"
                           Text="تفاصيل الأصناف داخل الفاتورة"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>

                <!-- Lines Grid -->
                <Border Grid.Row="2"
                        Background="White"
                        CornerRadius="12"
                        BorderBrush="#D0D7DD"
                        BorderThickness="1"
                        Padding="10">
                    <DataGrid x:Name="LinesGrid"
                              AutoGenerateColumns="False"
                              Style="{StaticResource MinimalDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="الصنف" Binding="{Binding ProductName}" Width="220"/>
                            <DataGridTextColumn Header="الوحدة" Binding="{Binding UnitName}" Width="120"/>
                            <DataGridTextColumn Header="الكمية" Binding="{Binding Quantity}" Width="90"/>

                            <DataGridTextColumn Header="سعر البيع" Binding="{Binding UnitPrice}" Width="110"/>
                            <DataGridTextColumn Header="SubTotal" Binding="{Binding LineSubTotal}" Width="120"/>

                            <DataGridTextColumn Header="ضريبة" Binding="{Binding TaxAmount}" Width="100"/>

                            <DataGridTextColumn Header="تكلفة/وحدة" Binding="{Binding UnitCost}" Width="120"/>
                            <DataGridTextColumn Header="COGS" Binding="{Binding CostTotal}" Width="120"/>

                            <DataGridTextColumn Header="ربح قبل الضريبة" Binding="{Binding ProfitBeforeTax}" Width="140"/>
                            <DataGridTextColumn Header="ربح بعد الضريبة" Binding="{Binding Profit}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </Grid>

    </Grid>
</Window>