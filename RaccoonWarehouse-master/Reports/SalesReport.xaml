<Window x:Class="RaccoonWarehouse.Reports.SalesReport"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        Title="تقرير المبيعات"
        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F2F6FA"
        FlowDirection="RightToLeft">

    <Window.Resources>

        <!-- Primary button -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2D8DCF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary button -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#E3EAF0"/>
            <Setter Property="Foreground" Value="#2D8DCF"/>
        </Style>

        <!-- Modern input -->
        <Style x:Key="InputBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CBD5DF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CBD5DF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Modern DataGrid -->
        <Style x:Key="MinimalDataGrid" TargetType="DataGrid">
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="ColumnHeaderHeight" Value="44"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="BorderBrush" Value="#D0D7DD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="AlternatingRowBackground" Value="#F7FAFD"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="60"/>
            <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#2D8DCF" Grid.Row="0">
            <TextBlock Text="تقرير المبيعات"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Filter -->
                <RowDefinition Height="Auto"/>
                <!-- Summary -->
                <RowDefinition Height="*"/>
                <!-- DataGrid -->
            </Grid.RowDefinitions>

            <!-- FILTER BAR -->
            <Border Grid.Row="0"
                    Background="White"
                    CornerRadius="12"
                    BorderBrush="#D0D7DD"
                    BorderThickness="1"
                    Padding="14"
                    Margin="0,0,0,15">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- From -->
                    <StackPanel Grid.Column="0" Margin="8,0">
                        <TextBlock Text="من تاريخ" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,6"/>
                        <DatePicker x:Name="FromDatePicker" Height="38" FontSize="15"/>
                    </StackPanel>

                    <!-- To -->
                    <StackPanel Grid.Column="1" Margin="8,0">
                        <TextBlock Text="إلى تاريخ" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,6"/>
                        <DatePicker x:Name="ToDatePicker" Height="38" FontSize="15"/>
                    </StackPanel>

                    <!-- Customer -->
                    <StackPanel Grid.Column="2" Margin="8,0">
                        <TextBlock Text="الزبون" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,6"/>
                        <ComboBox x:Name="CustomerComboBox"
                                  Style="{StaticResource ComboStyle}"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"/>
                    </StackPanel>

                    <!-- Invoice Type -->
                    <StackPanel Grid.Column="3" Margin="8,0">
                        <TextBlock Text="نوع الفاتورة" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,6"/>
                        <ComboBox x:Name="InvoiceTypeComboBox" Style="{StaticResource ComboStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4" Margin="8,0">
                        <TextBlock Text="مصدر الفاتورة" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,6"/>
                        <ComboBox x:Name="PosFilterComboBox" Style="{StaticResource ComboStyle}"/>
                    </StackPanel>

                    <!-- Buttons -->
                    <WrapPanel Grid.Column="5"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Bottom"
                               Margin="8,0">
                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                Width="160"
                                Click="GenerateReportBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <fa:ImageAwesome Icon="File" Width="16" Height="16"/>
                                <TextBlock Text=" عرض التقرير" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Width="130"
                                Margin="10,0,0,0"
                                Click="ExportPdfBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <fa:ImageAwesome Icon="Download" Width="16" Height="16"/>
                                <TextBlock Text=" تصدير PDF" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Width="120"
                                Margin="10,0,0,0"
                                Click="PrintBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <fa:ImageAwesome Icon="Print" Width="16" Height="16"/>
                                <TextBlock Text=" طباعة" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Width="120"
                                Margin="10,0,0,0"
                                Click="BackBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <fa:ImageAwesome Icon="ArrowLeft" Width="16" Height="16"/>
                                <TextBlock Text=" رجوع" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </Grid>
            </Border>

            <!-- SUMMARY CARDS -->
            <UniformGrid Grid.Row="1" Columns="7" Margin="0,0,0,12">
                <Border Background="White" CornerRadius="12" BorderBrush="#D0D7DD" BorderThickness="1" Padding="10" Margin="6">
                    <StackPanel>
                        <TextBlock Text="إجمالي البيع" Foreground="#666"/>
                        <TextBlock x:Name="TotalSalesText" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" BorderBrush="#D0D7DD" BorderThickness="1" Padding="10" Margin="6">
                    <StackPanel>
                        <TextBlock Text="الضريبة" Foreground="#666"/>
                        <TextBlock x:Name="TotalTaxText" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" BorderBrush="#D0D7DD" BorderThickness="1" Padding="10" Margin="6">
                    <StackPanel>
                        <TextBlock Text="الخصم" Foreground="#666"/>
                        <TextBlock x:Name="TotalDiscountText" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" BorderBrush="#D0D7DD" BorderThickness="1" Padding="10" Margin="6">
                    <StackPanel>
                        <TextBlock Text="المرتجعات" Foreground="#666"/>
                        <TextBlock x:Name="TotalReturnsText" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

               

                <Border Background="White" CornerRadius="12" BorderBrush="#D0D7DD" BorderThickness="1" Padding="10" Margin="6">
                    <StackPanel>
                        <TextBlock Text="COGS" Foreground="#666"/>
                        <TextBlock x:Name="TotalCogsText" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" BorderBrush="#D0D7DD" BorderThickness="1" Padding="10" Margin="6">
                    <StackPanel>
                        <TextBlock Text="الربح" Foreground="#666"/>
                        <TextBlock x:Name="GrossProfitText" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- RESULTS GRID -->
            <Border Grid.Row="2"
                    Background="White"
                    CornerRadius="12"
                    BorderBrush="#D0D7DD"
                    BorderThickness="1"
                    Padding="10">

                <DataGrid x:Name="SalesReportGrid"
                          AutoGenerateColumns="False"
                          Style="{StaticResource MinimalDataGrid}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="رقم الفاتورة" Binding="{Binding InvoiceNumber}" Width="180"/>
                        <DataGridTextColumn Header="التاريخ" Binding="{Binding Date, StringFormat=yyyy-MM-dd}" Width="140"/>
                        <DataGridTextColumn Header="الزبون" Binding="{Binding CustomerName}" Width="220"/>
                        <DataGridTextColumn Header="قبل الضريبة" Binding="{Binding SubTotal}" Width="140"/>
                        <DataGridTextColumn Header="الضريبة" Binding="{Binding TotalTax}" Width="120"/>
                        <DataGridTextColumn Header="الخصم" Binding="{Binding Discount}" Width="120"/>
                        <DataGridTextColumn Header="الإجمالي" Binding="{Binding Total}" Width="140"/>

                        <!-- ✅ NEW -->
                        <DataGridTextColumn Header="التكلفة (COGS)" Binding="{Binding Cogs}" Width="140"/>
                        <DataGridTextColumn Header="الربح" Binding="{Binding Profit}" Width="140"/>

                        <DataGridTextColumn Header="نوع" Binding="{Binding InvoiceType}" Width="130"/>
                        <DataGridTextColumn Header="طريقة الدفع" Binding="{Binding PaymentMethod}" Width="140"/>
                        <DataGridTextColumn Header="الحالة" Binding="{Binding Status}" Width="140"/>
                    </DataGrid.Columns>
                </DataGrid>

            </Border>
        </Grid>

        <!-- FOOTER -->
        <Border Background="#E3EAF0" Grid.Row="2">
            <TextBlock Text="© 2025 Raccoon Warehouse"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="#2D8DCF"
                       FontWeight="SemiBold"
                       FontSize="14"/>
        </Border>
    </Grid>
</Window>
