<Window x:Class="RaccoonWarehouse.Reports.CreditSalesReport"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        Title="تقرير مبيعات الذمم"
        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#EEF3F7"
        FlowDirection="RightToLeft">

    <Window.Resources>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#EEF3F7"/>
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#F8FBFD"/>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D6DEE6"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2F83C5"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#235F90"/>
        <SolidColorBrush x:Key="SoftBrush" Color="#E6EEF5"/>

        <LinearGradientBrush x:Key="HeroBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#356FA8" Offset="0"/>
            <GradientStop Color="#0F5B52" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{StaticResource SoftBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryDarkBrush}"/>
        </Style>

        <Style x:Key="ReportDataGridStyle" TargetType="DataGrid">
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="ColumnHeaderHeight" Value="46"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E9EEF3"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="BorderBrush" Value="#D6DEE6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FBFD"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F1F6FA"/>
                        <Setter Property="Foreground" Value="#27445D"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="BorderBrush" Value="#DDE5EC"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="TextBlock.TextAlignment" Value="Center"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="22,20,22,14" CornerRadius="28" Padding="24" Background="{StaticResource HeroBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#214F77" CornerRadius="20" Padding="16,12">
                    <StackPanel>
                        <TextBlock Text="إجمالي المتبقي" Foreground="#CFE3F3" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TotalRemainingText" Text="0.00" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="مبيعات الذمم" Foreground="White" FontSize="31" FontWeight="Bold" HorizontalAlignment="Right"/>
                    <TextBlock Text="يعرض فواتير البيع الآجل مع المبلغ المحصل والمتبقي الفعلي اعتماداً على الحركات المالية المرتبطة بالفاتورة." Foreground="#D3E6F3" FontSize="15" Margin="0,6,0,0" HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="22,0,22,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="22" Padding="18" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="190"/>
                        <ColumnDefinition Width="190"/>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="8,0">
                        <TextBlock Text="من تاريخ" FontWeight="SemiBold" Foreground="#27445D" Margin="0,0,0,6"/>
                        <DatePicker x:Name="FromDatePicker" Height="42" FontSize="15"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="8,0">
                        <TextBlock Text="إلى تاريخ" FontWeight="SemiBold" Foreground="#27445D" Margin="0,0,0,6"/>
                        <DatePicker x:Name="ToDatePicker" Height="42" FontSize="15"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="8,0">
                        <TextBlock Text="الزبون" FontWeight="SemiBold" Foreground="#27445D" Margin="0,0,0,6"/>
                        <ComboBox x:Name="CustomerComboBox" Height="42" FontSize="15"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="8,0">
                        <TextBlock Text="حالة المديونية" FontWeight="SemiBold" Foreground="#27445D" Margin="0,0,0,6"/>
                        <ComboBox x:Name="StatusComboBox" Height="42" FontSize="15"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                        <TextBlock Text="عدد الفواتير:" Foreground="#6A7C8E" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock x:Name="TotalInvoicesText" Text="0" Foreground="#27445D" FontSize="14" FontWeight="Bold" Margin="0,0,18,0"/>
                        <TextBlock Text="إجمالي الفواتير:" Foreground="#6A7C8E" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock x:Name="TotalDueText" Text="0.00" Foreground="#27445D" FontSize="14" FontWeight="Bold" Margin="0,0,18,0"/>
                        <TextBlock Text="المحصل:" Foreground="#6A7C8E" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock x:Name="TotalPaidText" Text="0.00" Foreground="#27445D" FontSize="14" FontWeight="Bold"/>
                    </StackPanel>

                    <Button Grid.Column="5" Width="150" Margin="12,0,0,0" Style="{StaticResource PrimaryButtonStyle}" Click="GenerateReportBtn_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <fa:ImageAwesome Icon="File" Width="15" Height="15"/>
                            <TextBlock Text=" عرض التقرير" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="6" Width="110" Style="{StaticResource SecondaryButtonStyle}" Click="BackBtn_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <fa:ImageAwesome Icon="ArrowLeft" Width="15" Height="15"/>
                            <TextBlock Text=" رجوع" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="24" Padding="14">
                <DataGrid x:Name="CreditSalesReportGrid" AutoGenerateColumns="False" Style="{StaticResource ReportDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="رقم الفاتورة" Binding="{Binding InvoiceNumber}" Width="140"/>
                        <DataGridTextColumn Header="تاريخ الفاتورة" Binding="{Binding Date, StringFormat=yyyy-MM-dd}" Width="140"/>
                        <DataGridTextColumn Header="اسم الزبون" Binding="{Binding CustomerName}" Width="240"/>
                        <DataGridTextColumn Header="إجمالي الفاتورة" Binding="{Binding InvoiceTotal}" Width="140"/>
                        <DataGridTextColumn Header="المبلغ المحصل" Binding="{Binding AmountPaid}" Width="140"/>
                        <DataGridTextColumn Header="المتبقي" Binding="{Binding RemainingAmount}" Width="130"/>
                        <DataGridTextColumn Header="الحالة" Binding="{Binding Status}" Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Margin="22,0,22,20" Background="#E8EEF3" CornerRadius="18" Padding="12">
            <TextBlock Text="© 2026 Raccoon Warehouse" HorizontalAlignment="Center" Foreground="#416784" FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>
