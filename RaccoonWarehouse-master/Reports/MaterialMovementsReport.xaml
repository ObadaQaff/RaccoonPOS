<Window x:Class="RaccoonWarehouse.Reports.MaterialMovementsReport"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        Title="حركات المواد"
        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <!-- Primary button style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3396D3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                              CornerRadius="8"
                              Padding="15,8"
                              BorderBrush="{TemplateBinding BorderBrush}"
                              BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBCB90"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FFF0CE"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary button style -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#FFF0CE"/>
            <Setter Property="Foreground" Value="#3396D3"/>
        </Style>
    </Window.Resources>

    <Grid Background="#EEEEEE">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#3396D3" Grid.Row="0">
            <TextBlock Text="حركات المواد"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Width="1000" HorizontalAlignment="Center" Margin="0,20,0,20">

                <!-- تاريخ البداية -->
                <TextBlock Text="تاريخ البداية" FlowDirection="RightToLeft" FontSize="18"/>
                <DatePicker Height="44" FontSize="18" Margin="0,0,0,20"/>

                <!-- تاريخ النهاية -->
                <TextBlock Text="تاريخ النهاية" FlowDirection="RightToLeft" FontSize="18"/>
                <DatePicker Height="44" FontSize="18" Margin="0,0,0,20"/>

                <!-- اختيار المستودع -->
                <TextBlock Text="المستودع" FlowDirection="RightToLeft" FontSize="18"/>
                <ComboBox Height="44" FontSize="18" Margin="0,0,0,20">
                    <ComboBoxItem Content="المستودع الرئيسي"/>
                    <ComboBoxItem Content="مستودع الفرع"/>
                </ComboBox>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,20,0,0">
                    <Button x:Name="BackBtn"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="200"
                            Click="BackBtn_Click"
                            Margin="0,0,20,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <fa:ImageAwesome Icon="ArrowLeft" Width="18" Height="18"
                                             Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text=" رجوع" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="GenerateReportBtn"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="200"
                            Click="GenerateReportBtn_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <fa:ImageAwesome Icon="File" Width="18" Height="18"
                                             Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text=" عرض التقرير" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- جدول عرض النتائج -->
                <DataGrid x:Name="MaterialMovementsGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          Margin="0,20,0,0"
                          Height="400">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="رقم الحركة" Binding="{Binding MovementID}" Width="*"/>
                        <DataGridTextColumn Header="تاريخ الحركة" Binding="{Binding Date}" Width="*"/>
                        <DataGridTextColumn Header="اسم المنتج" Binding="{Binding ProductName}" Width="*"/>
                        <DataGridTextColumn Header="الكمية" Binding="{Binding Quantity}" Width="*"/>
                        <DataGridTextColumn Header="نوع الحركة" Binding="{Binding MovementType}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

            </StackPanel>
        </ScrollViewer>

        <!-- FOOTER -->
        <Border Background="#FFF0CE" Grid.Row="2">
            <TextBlock Text="© 2025 Raccoon Warehouse"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="#3396D3"
                       FontSize="14"
                       FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>
